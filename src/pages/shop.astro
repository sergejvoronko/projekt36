---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Shop — projekt36"
  description="Curated parts, tools, and materials for BMW E36 builds. Sourced from what actually works on real projects."
>
  <section class="shop-hero">
    <div class="shop-hero-img" aria-hidden="true">
      <img src="/images/IMG_0511 (1).webp" alt="" width="900" height="400" loading="eager" decoding="async" />
      <div class="shop-hero-overlay"></div>
    </div>
    <div class="inner shop-hero-inner">
      <div class="page-tag">PROJEKT36 · SHOP</div>
      <h1 class="hero-title">The <em>Shop</em></h1>
      <p class="hero-sub">Curated parts, tools, and materials from real E36 build experience. No filler, no affiliate padding — just what works.</p>
    </div>
  </section>

  <section class="shop-body">
    <div class="inner">
      <div class="coming-soon-block">
        <div class="cs-icon">[ ]</div>
        <h2 class="cs-title">Coming soon</h2>
        <p class="cs-desc">
          The shop is being put together. It will carry a curated selection of parts and consumables
          used across the E36 build — sourced, tested, and selected for value.
        </p>
        <a href="/guides" class="btn-outline">Browse the guides in the meantime →</a>
      </div>

      <div class="gpsr-notice">
        <div class="gpsr-notice-label">EU PRODUCT SAFETY — GPSR</div>
        <p>
          Products sold through this shop are fulfilled by Printify on a print-on-demand basis.
          In accordance with Regulation (EU) 2023/988 (GPSR), the designated EU responsible person is:
        </p>
        <div class="gpsr-card">
          <strong>HONSON VENTURES LIMITED</strong><br />
          3, Gnaftis House flat 102, Limassol, Mesa Geitonia, 4003 CY — Cyprus<br />
          <a href="mailto:gpsr@honsonventures.com">gpsr@honsonventures.com</a>
        </div>
        <a href="/legal#gpsr" class="gpsr-more">Full legal information →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .shop-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    min-height: 320px;
    display: flex;
    align-items: flex-end;
  }
  .shop-hero-img {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .shop-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    filter: brightness(0.4) saturate(0.7);
  }
  .shop-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(19,23,32,1) 0%, rgba(19,23,32,0.55) 60%, rgba(19,23,32,0.25) 100%);
  }
  .inner { max-width: var(--wide-w); margin: 0 auto; }
  .shop-hero-inner {
    position: relative;
    z-index: 1;
    padding: 5rem 1.5rem 3rem;
    width: 100%;
  }
  .page-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.05;
  }
  .hero-title em { font-style: italic; font-weight: 400; color: var(--accent); }
  .hero-sub { font-size: 0.95rem; color: var(--text-mid); max-width: 56ch; line-height: 1.75; }

  .shop-body { padding: 5rem 1.5rem; }
  .coming-soon-block {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .cs-icon {
    font-family: var(--font-mono);
    font-size: 2rem;
    color: var(--text-dim);
  }
  .cs-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text);
  }
  .cs-desc {
    font-size: 0.92rem;
    color: var(--text-mid);
    line-height: 1.75;
  }

  .gpsr-notice {
    max-width: 560px;
    margin: 4rem auto 0;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }
  .gpsr-notice-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .gpsr-notice p {
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.75;
    margin-bottom: 0.85rem;
  }
  .gpsr-card {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-mid);
    background: var(--bg2);
    border: 1px solid var(--border);
    border-left: 2px solid rgba(212,149,42,.3);
    padding: 0.85rem 1rem;
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }
  .gpsr-card strong { color: var(--text); }
  .gpsr-card a { color: var(--accent); }
  .gpsr-more {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    text-decoration: none;
  }
  .gpsr-more:hover { color: var(--accent); }
</style>
