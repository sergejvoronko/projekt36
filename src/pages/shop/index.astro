---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';

interface PrintifyImage {
  src: string;
  is_default: boolean;
  position: string;
}
interface PrintifyVariant {
  price: number;
  is_enabled: boolean;
  is_available: boolean;
}
interface PrintifyProduct {
  id: string;
  title: string;
  description: string;
  images: PrintifyImage[];
  variants: PrintifyVariant[];
  tags: string[];
  visible: boolean;
}

const runtime = (Astro.locals as any).runtime;
const token   = runtime?.env?.PRINTIFY_API_TOKEN   ?? import.meta.env.PRINTIFY_API_TOKEN;
const shopId  = runtime?.env?.PRINTIFY_SHOP_ID      ?? import.meta.env.PRINTIFY_SHOP_ID;

let products: PrintifyProduct[] = [];
let fetchError = '';

if (token && shopId) {
  try {
    const res = await fetch(
      `https://api.printify.com/v1/shops/${shopId}/products.json?limit=20`,
      { headers: { Authorization: `Bearer ${token}` } }
    );
    if (res.ok) {
      const data = await res.json() as { data: PrintifyProduct[] };
      products = data.data.filter(p => p.visible);
    } else {
      fetchError = `${res.status} ${res.statusText}`;
    }
  } catch {
    fetchError = 'Network error';
  }
}

function defaultImage(p: PrintifyProduct) {
  return p.images.find(i => i.is_default)?.src ?? p.images[0]?.src ?? '';
}
function minPrice(p: PrintifyProduct) {
  const prices = p.variants
    .filter(v => v.is_enabled && v.is_available)
    .map(v => v.price);
  return prices.length ? Math.min(...prices) : 0;
}
function fmtPrice(cents: number) {
  return `€\u202f${(cents / 100).toFixed(2)}`;
}
---

<BaseLayout
  title="Shop — projekt36"
  description="projekt36-branded gear for BMW E36 enthusiasts."
>
  <section class="shop-hero">
    <div class="shop-hero-img" aria-hidden="true">
      <img src="/images/IMG_0511 (1).webp" alt="" width="900" height="400" loading="eager" decoding="async" />
      <div class="shop-hero-overlay"></div>
    </div>
    <div class="inner shop-hero-inner">
      <div class="page-tag">PROJEKT36 · SHOP</div>
      <h1 class="hero-title">The <em>Shop</em></h1>
      <p class="hero-sub">projekt36-branded gear for people who actually turn wrenches.</p>
    </div>
  </section>

  <section class="shop-body">
    <div class="inner">

      {fetchError && (
        <div class="fetch-error">
          <span class="fe-label">API</span> Could not load products ({fetchError})
        </div>
      )}

      {!fetchError && products.length === 0 && (
        <div class="empty-state">
          <div class="es-icon">[ ]</div>
          <h2 class="es-title">Coming soon</h2>
          <p class="es-desc">
            The shop is being put together. It will carry a curated selection of
            projekt36-branded items — designed for E36 owners who appreciate the craft.
          </p>
          <a href="/guides" class="btn-outline">Browse the guides in the meantime →</a>
        </div>
      )}

      {products.length > 0 && (
        <div class="product-grid">
          {products.map(p => (
            <a href={`/shop/${p.id}`} class="product-card">
              <div class="pc-image-wrap">
                <img
                  src={defaultImage(p)}
                  alt={p.title}
                  loading="lazy"
                  decoding="async"
                  width="480"
                  height="480"
                />
              </div>
              <div class="pc-info">
                {p.tags?.[0] && <div class="pc-tag">{p.tags[0]}</div>}
                <h2 class="pc-title">{p.title}</h2>
                <div class="pc-footer">
                  <span class="pc-price">{fmtPrice(minPrice(p))}</span>
                  <span class="pc-cta">View →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

      <div class="gpsr-notice">
        <div class="gpsr-notice-label">EU PRODUCT SAFETY — GPSR</div>
        <p>
          Products sold through this shop are fulfilled by Printify on a print-on-demand basis.
          In accordance with Regulation (EU) 2023/988 (GPSR), the designated EU responsible person is:
        </p>
        <div class="gpsr-card">
          <strong>HONSON VENTURES LIMITED</strong><br />
          3, Gnaftis House flat 102, Limassol, Mesa Geitonia, 4003 CY — Cyprus<br />
          <a href="mailto:gpsr@honsonventures.com">gpsr@honsonventures.com</a>
        </div>
        <a href="/legal#gpsr" class="gpsr-more">Full legal information →</a>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .shop-hero {
    position: relative; overflow: hidden; border-bottom: 1px solid var(--border);
    min-height: 280px; display: flex; align-items: flex-end;
  }
  .shop-hero-img { position: absolute; inset: 0; z-index: 0; }
  .shop-hero-img img { width: 100%; height: 100%; object-fit: cover; object-position: center 40%; filter: brightness(0.4) saturate(0.7); }
  .shop-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(19,23,32,1) 0%, rgba(19,23,32,0.55) 60%, rgba(19,23,32,0.25) 100%);
  }
  .inner { max-width: var(--wide-w); margin: 0 auto; }
  .shop-hero-inner { position: relative; z-index: 1; padding: 5rem 1.5rem 3rem; width: 100%; }
  .page-tag { font-family: var(--font-mono); font-size: 0.65rem; color: var(--accent); letter-spacing: 0.22em; text-transform: uppercase; margin-bottom: 0.75rem; }
  .hero-title { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 700; margin-bottom: 0.75rem; line-height: 1.05; }
  .hero-title em { font-style: italic; font-weight: 400; color: var(--accent); }
  .hero-sub { font-size: 0.95rem; color: var(--text-mid); max-width: 56ch; line-height: 1.75; }

  /* Body */
  .shop-body { padding: 4rem 1.5rem 6rem; }

  /* Error */
  .fetch-error {
    font-family: var(--font-mono); font-size: 0.78rem; color: var(--red);
    background: rgba(217,83,79,0.06); border: 1px solid rgba(217,83,79,0.2);
    padding: 0.65rem 1rem; margin-bottom: 2rem;
  }
  .fe-label { color: var(--accent); margin-right: 0.5rem; }

  /* Empty state */
  .empty-state {
    max-width: 480px; margin: 0 auto; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 1.25rem;
    padding: 4rem 0;
  }
  .es-icon { font-family: var(--font-mono); font-size: 2rem; color: var(--text-dim); }
  .es-title { font-size: 1.5rem; font-weight: 600; color: var(--text); }
  .es-desc { font-size: 0.9rem; color: var(--text-mid); line-height: 1.75; }

  /* Product grid */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 5rem;
  }
  @media (max-width: 900px) { .product-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .product-grid { grid-template-columns: 1fr; } }

  .product-card {
    display: flex; flex-direction: column;
    background: var(--bg2); border: 1px solid var(--border);
    text-decoration: none; transition: border-color 0.15s, transform 0.15s;
    overflow: hidden;
  }
  .product-card:hover { border-color: var(--border-mid); transform: translateY(-2px); }

  .pc-image-wrap {
    aspect-ratio: 1; overflow: hidden; background: var(--bg3);
  }
  .pc-image-wrap img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.3s ease;
  }
  .product-card:hover .pc-image-wrap img { transform: scale(1.04); }

  .pc-info { padding: 1rem 1.1rem 1.1rem; display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }
  .pc-tag { font-family: var(--font-mono); font-size: 0.58rem; color: var(--accent); letter-spacing: 0.14em; text-transform: uppercase; }
  .pc-title { font-size: 0.95rem; font-weight: 600; color: var(--text); line-height: 1.3; }
  .product-card:hover .pc-title { color: var(--accent); }

  .pc-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 0.75rem; }
  .pc-price { font-family: var(--font-mono); font-size: 0.88rem; color: var(--text); font-weight: 600; }
  .pc-cta { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-dim); transition: color 0.15s; }
  .product-card:hover .pc-cta { color: var(--accent); }

  /* GPSR */
  .gpsr-notice { max-width: 560px; margin: 0 auto; padding-top: 2.5rem; border-top: 1px solid var(--border); }
  .gpsr-notice-label { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-dim); letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 0.75rem; }
  .gpsr-notice p { font-size: 0.82rem; color: var(--text-dim); line-height: 1.75; margin-bottom: 0.85rem; }
  .gpsr-card {
    font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-mid);
    background: var(--bg2); border: 1px solid var(--border); border-left: 2px solid rgba(212,149,42,.3);
    padding: 0.85rem 1rem; line-height: 1.75; margin-bottom: 0.75rem;
  }
  .gpsr-card strong { color: var(--text); }
  .gpsr-card a { color: var(--accent); }
  .gpsr-more { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-dim); text-decoration: none; }
  .gpsr-more:hover { color: var(--accent); }
</style>
