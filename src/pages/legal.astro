---
import BaseLayout from '../layouts/BaseLayout.astro';
const updated = '2025-01-01';
---

<BaseLayout
  title="Privacy, Cookies & Legal — projekt36"
  description="Privacy policy, cookie policy, GPSR compliance, and affiliate disclosure for projekt36.com."
>
<div class="legal-page">

  <div class="legal-hero">
    <div class="legal-tag">PROJEKT36 · LEGAL</div>
    <h1 class="legal-title">Privacy, Cookies &amp; Legal</h1>
    <p class="legal-lead">Last updated: {updated}</p>
  </div>

  <!-- ═══ PRIVACY POLICY ═══ -->
  <section class="legal-section" id="privacy">
    <div class="legal-section-tag">Privacy Policy</div>
    <h2 class="legal-h2">What data we collect</h2>
    <p>
      projekt36.com does not use analytics cookies, advertising trackers, or any form of
      user profiling. No personal data is collected during ordinary browsing of this site.
    </p>
    <p>
      If you use the email subscription form, your email address is stored solely for the
      purpose of sending build update notifications. It is not shared with third parties,
      sold, or used for any other purpose. You can unsubscribe at any time.
    </p>
    <p>
      This site is operated from Ukraine. If you contact us by email, any correspondence
      is handled according to GDPR principles — retained only as long as necessary, and
      deleted on request.
    </p>

    <h2 class="legal-h2" style="margin-top:2rem">Third-party services</h2>
    <p>
      <strong>Google Fonts</strong> — If you accept cookies, this site loads typefaces from
      Google Fonts (fonts.googleapis.com). This causes your browser to make a request to
      Google's servers, which may process your IP address in accordance with
      <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Google's privacy policy</a>.
      If you decline cookies, system fonts are used instead.
    </p>
    <p>
      <strong>Printify</strong> — The shop section uses Printify for print-on-demand
      fulfilment. When you place an order, your shipping and payment details are processed
      by Printify and its payment partners. Their privacy policy applies to that transaction.
    </p>

    <h2 class="legal-h2" style="margin-top:2rem">Your rights (GDPR)</h2>
    <p>
      Under GDPR you have the right to access, correct, or delete any personal data we hold
      about you. To exercise these rights, contact us at
      <a href="mailto:legal@projekt36.com">legal@projekt36.com</a>.
    </p>
  </section>

  <!-- ═══ COOKIE POLICY ═══ -->
  <section class="legal-section" id="cookies">
    <div class="legal-section-tag">Cookie Policy</div>
    <h2 class="legal-h2">Cookies used on this site</h2>
    <p>
      This site uses <strong>no tracking cookies</strong> and no advertising cookies.
      The only storage used is <code>localStorage</code> to remember your cookie preference.
    </p>

    <div class="legal-table-wrap">
      <table class="legal-table">
        <thead>
          <tr><th>Name</th><th>Type</th><th>Purpose</th><th>Duration</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><code>p36_consent</code></td>
            <td>localStorage</td>
            <td>Stores your cookie preference (accepted / essential only)</td>
            <td>Until cleared</td>
          </tr>
          <tr>
            <td>Google Fonts</td>
            <td>Third-party request</td>
            <td>Loads IBM Plex Sans, IBM Plex Mono, and Playfair Display typefaces. Only loaded if you accept cookies.</td>
            <td>Browser cache</td>
          </tr>
        </tbody>
      </table>
    </div>

    <p>
      To change your cookie preference, clear your browser's local storage for projekt36.com,
      or use the button below:
    </p>
    <button id="reset-consent" class="btn-outline" style="margin-top:.5rem">
      Reset cookie preference →
    </button>
    <script is:inline>
      document.getElementById('reset-consent')?.addEventListener('click', function() {
        localStorage.removeItem('p36_consent');
        location.reload();
      });
    </script>
  </section>

  <!-- ═══ GPSR ═══ -->
  <section class="legal-section legal-section-alt" id="gpsr">
    <div class="legal-section-tag">GPSR — EU Product Safety</div>
    <h2 class="legal-h2">General Product Safety Regulation</h2>
    <p>
      In accordance with Regulation (EU) 2023/988 (General Product Safety Regulation, GPSR),
      effective 13 December 2024, the following EU-based responsible person is designated for
      products sold through this site:
    </p>

    <div class="legal-gpsr-card">
      <div class="gpsr-label">EU RESPONSIBLE PERSON</div>
      <div class="gpsr-name">HONSON VENTURES LIMITED</div>
      <div class="gpsr-detail">3, Gnaftis House flat 102</div>
      <div class="gpsr-detail">Limassol, Mesa Geitonia</div>
      <div class="gpsr-detail">4003 CY — Cyprus</div>
      <div class="gpsr-contact">
        <a href="mailto:gpsr@honsonventures.com">gpsr@honsonventures.com</a>
      </div>
    </div>

    <p>
      Products sold through the projekt36 shop are produced by Printify on a print-on-demand
      basis. Safety declarations, technical documentation, and product conformity information
      can be requested by contacting the EU responsible person above.
    </p>
    <p>
      To report a product safety concern, contact:
      <a href="mailto:gpsr@honsonventures.com">gpsr@honsonventures.com</a>
    </p>
  </section>

  <!-- ═══ AFFILIATE DISCLOSURE ═══ -->
  <section class="legal-section" id="affiliate">
    <div class="legal-section-tag">Affiliate &amp; Commercial Disclosure</div>
    <h2 class="legal-h2">Affiliate policy</h2>
    <p>
      projekt36 guides are written from direct build experience. They are not sponsored,
      commissioned by parts suppliers, or written to promote specific products.
    </p>
    <p>
      Where parts or suppliers are mentioned in guides, they reflect what was actually used
      on the build. If any guide contains an affiliate link — a link that earns a commission
      if you purchase — it will be marked with <strong>[affiliate link]</strong> inline and
      disclosed at the top of that article.
    </p>
    <p>
      At the time of writing, <strong>no affiliate links are active on this site</strong>.
      If this changes, the policy and disclosures will be updated accordingly.
    </p>
    <p>
      The shop sells projekt36-branded items fulfilled through Printify. This is the site's
      own merchandise — there is no affiliate relationship with Printify as a referral scheme.
    </p>
  </section>

  <!-- ═══ CONTACT ═══ -->
  <section class="legal-section">
    <div class="legal-section-tag">Contact</div>
    <h2 class="legal-h2">Legal enquiries</h2>
    <p>
      For any legal, privacy, or GDPR-related requests:
      <a href="mailto:legal@projekt36.com">legal@projekt36.com</a>
    </p>
    <p>
      For GPSR product safety matters, contact the EU responsible person listed above.
    </p>
  </section>

</div>
</BaseLayout>

<style>
  .legal-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  .legal-hero { margin-bottom: 2.5rem; }
  .legal-tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .legal-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .legal-lead { font-size: 0.82rem; color: var(--text-dim); font-family: var(--font-mono); }

  .legal-section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
  }
  .legal-section-alt {
    background: var(--bg2);
    padding: 2.5rem 2rem;
    margin: 0 -2rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .legal-section-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--accent);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  .legal-h2 {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .legal-section p,
  .legal-section-alt p {
    font-size: 0.9rem;
    color: var(--text-mid);
    line-height: 1.85;
    margin-bottom: 1rem;
    max-width: 64ch;
  }
  .legal-section a,
  .legal-section-alt a { color: var(--accent); }
  .legal-section a:hover,
  .legal-section-alt a:hover { text-decoration: underline; }
  code {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: var(--bg3);
    padding: 0.1em 0.4em;
    border-radius: 2px;
    color: var(--accent);
  }

  /* Cookie table */
  .legal-table-wrap { overflow-x: auto; margin: 1rem 0 1.5rem; }
  .legal-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.84rem;
  }
  .legal-table th {
    background: var(--bg3);
    padding: 0.5rem 0.85rem;
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    border-bottom: 2px solid rgba(212,149,42,.25);
  }
  .legal-table td {
    padding: 0.5rem 0.85rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-mid);
    vertical-align: top;
    line-height: 1.6;
  }
  .legal-table tr:hover td { background: var(--bg3); }

  /* GPSR card */
  .legal-gpsr-card {
    background: var(--bg);
    border: 1px solid var(--border-mid);
    border-left: 3px solid var(--accent);
    padding: 1.25rem 1.5rem;
    margin: 1.25rem 0;
    display: inline-block;
    min-width: 280px;
  }
  .gpsr-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--accent);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  .gpsr-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.35rem;
  }
  .gpsr-detail {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-mid);
    line-height: 1.7;
  }
  .gpsr-contact {
    margin-top: 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .gpsr-contact a { color: var(--accent); }

  .btn-outline {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-mid);
    background: transparent;
    border: 1px solid var(--border-mid);
    padding: 0.5rem 1.1rem;
    cursor: pointer;
    letter-spacing: 0.06em;
    transition: all 0.15s;
    text-decoration: none;
  }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

  @media (max-width: 560px) {
    .legal-section-alt { margin: 0 -1.5rem; padding: 2.5rem 1.5rem; }
  }
</style>
