---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(a => ({ params: { slug: a.slug }, props: { article: a } }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const pillarLabels: Record<string, string> = {
  engine:    'Engine',
  swap:      'Swap',
  body:      'Body & Paint',
  suspension:'Suspension',
  interior:  'Interior',
  reference: 'Reference',
};
---

<BaseLayout title={`${article.data.title} — projekt36`} description={article.data.description}>
<article class="article-page">

  <div class="article-header">
    <div class="breadcrumb">
      <a href="/guides">Guides</a>
      <span class="sep">/</span>
      <span class="pillar-tag">{pillarLabels[article.data.pillar]}</span>
    </div>
    <h1 class="article-title">{article.data.title}</h1>
    <p class="article-desc">{article.data.description}</p>
  </div>

  <div class="article-body">
    <Content />
  </div>

  <div class="article-footer">
    <a href="/guides" class="btn-outline">← Back to guides</a>
  </div>

</article>
</BaseLayout>

<style>
  .article-page {
    max-width: var(--content-w);
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    display: flex;
    gap: 0.4rem;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--text-dim); transition: color 0.15s; }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { color: var(--border-mid); }
  .pillar-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--accent-dim);
    border: 1px solid rgba(212,149,42,0.2);
    padding: 0.15em 0.5em;
  }

  .article-header { margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
  .article-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }
  .article-desc { font-size: 0.95rem; color: var(--text-mid); line-height: 1.7; max-width: 58ch; }

  /* Article body typography */
  .article-body { line-height: 1.8; }

  .article-body :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
    margin: 2.5rem 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }
  .article-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin: 1.75rem 0 0.5rem;
  }
  .article-body :global(h4) {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 1.5rem 0 0.5rem;
  }
  .article-body :global(p) {
    color: var(--text-mid);
    margin-bottom: 1.1rem;
    font-size: 0.97rem;
  }
  .article-body :global(strong) { color: var(--text); font-weight: 600; }
  .article-body :global(em) { color: var(--accent); font-style: italic; }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0.75rem 0 1.25rem 1.5rem;
    color: var(--text-mid);
    font-size: 0.95rem;
  }
  .article-body :global(li) { margin-bottom: 0.4rem; line-height: 1.65; }

  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.85rem;
    font-family: var(--font-mono);
  }
  .article-body :global(th) {
    background: var(--bg2);
    color: var(--accent);
    font-weight: 600;
    text-align: left;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--border);
    letter-spacing: 0.04em;
  }
  .article-body :global(td) {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    color: var(--text-mid);
    vertical-align: top;
  }
  .article-body :global(tr:nth-child(even) td) { background: var(--bg2); }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    background: var(--accent-dim);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--text-mid);
  }

  .article-body :global(code) {
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 0.15em 0.4em;
    font-size: 0.85em;
    color: var(--accent);
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  .article-footer { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); }
</style>
