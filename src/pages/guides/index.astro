---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');

const pillars = [
  { key: 'engine',    label: 'Engine',       desc: 'M50 rebuild, failure points, comparisons' },
  { key: 'swap',      label: 'Swap',         desc: 'M43 → M50 conversion guides' },
  { key: 'body',      label: 'Body & Paint', desc: 'Rust, metalwork, PPF, paint' },
  { key: 'suspension',label: 'Suspension',   desc: 'Air ride, geometry, bushings' },
  { key: 'interior',  label: 'Interior',     desc: 'Sound deadening, leather, trim' },
  { key: 'reference', label: 'Reference',    desc: 'Torque specs, part numbers, suppliers' },
];

const byPillar = Object.fromEntries(
  pillars.map(p => [p.key, articles.filter(a => a.data.pillar === p.key)])
);

const pillarImages: Record<string, string> = {
  engine:     '/images/blueprint-m50-engine.webp',
  swap:       '/images/blueprint-m52-anatomy.webp',
  suspension: '/images/blueprint-front-suspension.webp',
  reference:  '/images/blueprint-rear-suspension.webp',
};

const sidebarTools = [
  { label: 'Wheel Fitment Calculator', href: '/tools/wheel-fitment', badge: 'Calc' },
  { label: 'Tire Size Compare',        href: '/tools/tire-compare',  badge: 'Calc' },
  { label: 'Offset & Spacer Tool',     href: '/tools/offset-spacer', badge: 'Calc' },
  { label: 'M43 → M50 Swap Checklist',href: '/tools/swap-checklist',badge: 'Swap' },
  { label: 'Build Budget Planner',     href: '/tools/build-budget',  badge: 'Plan' },
  { label: 'Air Suspension Checklist', href: '/tools/air-suspension',badge: 'Susp' },
];

const sbId = 'sb-guides';
---

<BaseLayout
  title="BMW E36 Technical Guides — projekt36"
  description="Technical guides for BMW E36 owners. Engine swaps, rust repair, cooling, suspension, sound deadening, and more."
>
<section class="page-hero-section">
  <div class="page-hero-img" aria-hidden="true">
    <img src="/images/blueprint-vanos.webp" alt="" width="1200" height="500" loading="eager" decoding="async" />
    <div class="page-hero-overlay"></div>
  </div>
  <div class="page-hero">
    <div class="page-tag">PROJEKT36 · TECHNICAL LIBRARY</div>
    <h1 class="page-title">E36 <em>Guides</em></h1>
    <p class="page-lead">
      {articles.length} technical guides covering the full E36 build — from engine swaps and rust to
      sound deadening and parts sourcing. Written from real build experience, not forum hearsay.
    </p>
  </div>
</section>

<div class="guides-wrap">

  <!-- ═══ MAIN ═══ -->
  <main class="guides-main">

    <!-- Schemas banner -->
    <a href="/schemas/e36-wiring.html" target="_blank" class="schemas-banner">
      <div class="schemas-banner-inner">
        <div>
          <div class="sb-tag">Interactive viewer</div>
          <div class="sb-title">BMW E36 Wiring Schemas</div>
          <div class="sb-desc">5 schemas, 10 SVG diagrams. Starting, charging, cooling, EWS, OBD, wipers, central locking, mirrors, seat heaters.</div>
        </div>
        <span class="sb-cta">Open viewer →</span>
      </div>
    </a>

    <!-- Articles by pillar -->
    {pillars.map(p => byPillar[p.key]?.length > 0 && (
      <section class="pillar-section" style={pillarImages[p.key] ? `--pillar-bg: url(${pillarImages[p.key]})` : ''}>
        <div class="pillar-head">
          <div class="pillar-title">{p.label}</div>
          <div class="pillar-desc">{p.desc}</div>
        </div>
        <div class="articles-list">
          {byPillar[p.key].map(a => (
            <a href={`/guides/${a.id}`} class="article-row">
              <div class="article-info">
                <h3 class="article-title">{a.data.title}</h3>
                <p class="article-desc">{a.data.description}</p>
              </div>
              <span class="article-arrow">→</span>
            </a>
          ))}
        </div>
      </section>
    ))}

  </main>

  <!-- ═══ SIDEBAR ═══ -->
  <aside class="guides-sidebar">

    <!-- Shop banner -->
    <a href="/shop/" class="side-shop-banner">
      <div class="side-shop-tag">// THE SHOP</div>
      <div class="side-shop-title">projekt36 Gear</div>
      <p class="side-shop-desc">
        Apparel and accessories for E36 enthusiasts.
        More products added as the build progresses.
      </p>
      <span class="side-shop-cta">Browse the shop →</span>
    </a>

    <!-- Tools -->
    <div class="side-block">
      <div class="side-block-label">// TOOLS</div>
      <ul class="side-tools">
        {sidebarTools.map(t => (
          <li>
            <a href={t.href} class="side-tool-row">
              <span class="side-tool-badge">{t.badge}</span>
              <span class="side-tool-label">{t.label}</span>
              <span class="side-tool-arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
      <a href="/tools/" class="side-tools-all">All tools →</a>
    </div>

    <!-- Subscribe -->
    <div class="side-block">
      <div class="side-block-label">// NEWSLETTER</div>
      <p class="side-sub-heading">Follow the swap.</p>
      <p class="side-sub-note">New guides, build chapters, and tool releases — no spam.</p>
      <form class="side-sub-form" id={sbId}>
        <input type="email" placeholder="your@email.com" required aria-label="Email address" class="side-sub-input" />
        <button type="submit" class="side-sub-btn">Subscribe</button>
      </form>
      <p class="side-sub-fine" id={`${sbId}-note`}>Unsubscribe any time.</p>
    </div>

  </aside>

</div>
</BaseLayout>

<script define:vars={{ sbId }}>
  document.getElementById(sbId)?.addEventListener('submit', e => {
    e.preventDefault();
    const form = e.currentTarget;
    const note = document.getElementById(`${sbId}-note`);
    form.querySelector('.side-sub-input').style.display = 'none';
    form.querySelector('.side-sub-btn').style.display = 'none';
    if (note) {
      note.textContent = '✓ You\'re in. Build updates coming.';
      note.style.color = 'var(--green)';
    }
  });
</script>

<style>
  /* ── LAYOUT ── */
  .guides-wrap {
    max-width: var(--wide-w);
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 0 3rem;
    align-items: start;
  }
  .guides-main { min-width: 0; }

  /* ── SIDEBAR ── */
  .guides-sidebar {
    position: sticky;
    top: 5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Shop banner */
  .side-shop-banner {
    display: block;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-top: 2px solid var(--accent);
    padding: 1.25rem 1.25rem 1rem;
    text-decoration: none;
    transition: background 0.15s;
  }
  .side-shop-banner:hover { background: var(--bg3); }
  .side-shop-tag {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--accent);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  .side-shop-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .side-shop-desc {
    font-size: 0.78rem;
    color: var(--text-mid);
    line-height: 1.55;
    margin-bottom: 0.75rem;
  }
  .side-shop-cta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
  }

  /* Side blocks */
  .side-block {
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 1.25rem;
  }
  .side-block-label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--accent);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  /* Tools list */
  .side-tools {
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem;
    display: flex;
    flex-direction: column;
  }
  .side-tool-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.12s;
  }
  .side-tools li:last-child .side-tool-row { border-bottom: none; }
  .side-tool-row:hover {
    background: var(--bg3);
    margin: 0 -1.25rem;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
  }
  .side-tool-badge {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    color: var(--text-dim);
    border: 1px solid var(--border-mid);
    padding: 1px 5px;
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .side-tool-label {
    font-size: 0.78rem;
    color: var(--text-mid);
    flex: 1;
    line-height: 1.3;
    transition: color 0.12s;
  }
  .side-tool-row:hover .side-tool-label { color: var(--accent); }
  .side-tool-arrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    transition: color 0.12s;
    flex-shrink: 0;
  }
  .side-tool-row:hover .side-tool-arrow { color: var(--accent); }
  .side-tools-all {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.15s;
  }
  .side-tools-all:hover { color: var(--accent); }

  /* Subscribe */
  .side-sub-heading {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.3rem;
  }
  .side-sub-note {
    font-size: 0.75rem;
    color: var(--text-dim);
    line-height: 1.5;
    margin-bottom: 0.9rem;
  }
  .side-sub-form { display: flex; flex-direction: column; gap: 6px; }
  .side-sub-input {
    background: var(--bg3);
    border: 1px solid var(--border-mid);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.55rem 0.75rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .side-sub-input:focus { border-color: var(--accent); }
  .side-sub-btn {
    background: var(--accent);
    color: var(--text-inverse);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.55rem 1rem;
    border: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .side-sub-btn:hover { opacity: 0.85; }
  .side-sub-fine {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--text-dim);
    margin-top: 0.35rem;
  }

  /* ── MAIN CONTENT ── */
  .page-hero-section {
    position: relative; overflow: hidden;
    border-bottom: 1px solid var(--border);
    min-height: 280px; display: flex; align-items: flex-end;
    margin-bottom: 2.5rem;
  }
  .page-hero-img { position: absolute; inset: 0; z-index: 0; }
  .page-hero-img img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.3) saturate(0.6); }
  .page-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, var(--bg) 0%, rgba(19,23,32,0.5) 60%, rgba(19,23,32,0.25) 100%);
  }
  .page-hero {
    position: relative; z-index: 1;
    padding: 5rem 1.5rem 2.5rem; width: 100%;
  }
  .page-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.22em;
    margin-bottom: 0.75rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.05;
  }
  .page-title em { font-style: italic; font-weight: 400; color: var(--accent); }
  .page-lead { font-size: 0.95rem; color: var(--text-mid); max-width: 58ch; line-height: 1.75; }

  .schemas-banner {
    display: block;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-top: 2px solid var(--accent);
    text-decoration: none;
    margin-bottom: 3rem;
    transition: border-color 0.15s, background 0.15s;
  }
  .schemas-banner:hover { background: var(--bg3); border-color: var(--border-mid); border-top-color: var(--accent); }
  .schemas-banner-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .sb-tag { font-family: var(--font-mono); font-size: 0.6rem; color: var(--accent); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.3rem; }
  .sb-title { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 0.35rem; }
  .sb-desc { font-size: 0.82rem; color: var(--text-mid); line-height: 1.5; max-width: 56ch; }
  .sb-cta { font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent); flex-shrink: 0; white-space: nowrap; }

  .pillar-section {
    margin-bottom: 3rem;
    position: relative;
  }
  .pillar-section[style] { overflow: hidden; }
  .pillar-section[style]::after {
    content: '';
    position: absolute;
    top: 0; right: -1rem; bottom: 0;
    width: 260px;
    background-image: var(--pillar-bg);
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center right;
    opacity: 0.04;
    pointer-events: none;
  }
  .pillar-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.5rem;
  }
  .pillar-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .pillar-desc { font-size: 0.8rem; color: var(--text-dim); }

  .articles-list { display: flex; flex-direction: column; }
  .article-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.12s;
  }
  .article-row:last-child { border-bottom: none; }
  .article-row:hover { background: var(--bg2); margin: 0 -1rem; padding-left: 1rem; padding-right: 1rem; }
  .article-info { flex: 1; min-width: 0; }
  .article-title { font-size: 0.95rem; font-weight: 600; color: var(--text); margin-bottom: 0.25rem; transition: color 0.15s; }
  .article-row:hover .article-title { color: var(--accent); }
  .article-desc { font-size: 0.8rem; color: var(--text-dim); line-height: 1.5; }
  .article-arrow { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-dim); flex-shrink: 0; transition: color 0.15s; }
  .article-row:hover .article-arrow { color: var(--accent); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .guides-wrap { grid-template-columns: 1fr; }
    .guides-sidebar {
      position: static;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
  }
  @media (max-width: 560px) {
    .guides-sidebar { grid-template-columns: 1fr; }
  }
</style>
