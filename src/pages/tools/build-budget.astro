---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Build Budget Planner — projekt36"
  description="Estimate your BMW E36 build cost by category. Values are saved automatically."
>
<div class="tool-page">
  <div class="breadcrumb">
    <a href="/tools">Tools</a>
    <span class="sep">/</span>
    <span>Build Budget Planner</span>
  </div>

  <div class="tool-header">
    <span class="tool-badge badge-plan">Planning</span>
    <h1>Build Budget Planner</h1>
    <p class="tool-desc">Estimate your total build cost by category. Values are saved automatically.</p>
  </div>

  <div class="tool-layout">
    <div class="tool-main">
      <div class="tool-form">
        <h3>Budget Categories (€)</h3>
        <div class="field-grid">
          <div class="field"><label class="field-label" for="bb-engine">Engine / Swap</label><input type="number" id="bb-engine" value="2500" min="0" /></div>
          <div class="field"><label class="field-label" for="bb-susp">Suspension</label><input type="number" id="bb-susp" value="900" min="0" /></div>
          <div class="field"><label class="field-label" for="bb-int">Interior</label><input type="number" id="bb-int" value="600" min="0" /></div>
          <div class="field"><label class="field-label" for="bb-paint">Paint / Body</label><input type="number" id="bb-paint" value="1800" min="0" /></div>
          <div class="field"><label class="field-label" for="bb-wheels">Wheels / Tires</label><input type="number" id="bb-wheels" value="1500" min="0" /></div>
          <div class="field"><label class="field-label" for="bb-diag">Diagnostics / Misc</label><input type="number" id="bb-diag" value="350" min="0" /></div>
          <div class="field"><label class="field-label" for="bb-elec">Electrical</label><input type="number" id="bb-elec" value="400" min="0" /></div>
          <div class="field"><label class="field-label" for="bb-sound">Sound Deadening</label><input type="number" id="bb-sound" value="250" min="0" /></div>
          <div class="field"><label class="field-label" for="bb-tools">Tools / Consumables</label><input type="number" id="bb-tools" value="300" min="0" /></div>
        </div>
        <button class="btn-calc" id="calc-btn">Calculate Total</button>
      </div>

      <div class="result-box" id="budget-result">
        <p class="result-placeholder">Enter values and press Calculate.</p>
      </div>
    </div>

    <aside class="tool-sidebar">
      <div class="sidebar-card">
        <h4>Realistic Ranges</h4>
        <div class="ref-table">
          <div class="ref-row"><span class="ref-key">M43→M50 swap</span><span class="ref-val">€1500–3500</span></div>
          <div class="ref-row"><span class="ref-key">Air ride (full)</span><span class="ref-val">€1200–2500</span></div>
          <div class="ref-row"><span class="ref-key">Full respray</span><span class="ref-val">€2000–6000</span></div>
          <div class="ref-row"><span class="ref-key">Wheels + tires</span><span class="ref-val">€800–3000</span></div>
          <div class="ref-row"><span class="ref-key">Sound deadening</span><span class="ref-val">€150–400</span></div>
          <div class="ref-row"><span class="ref-key">Interior refresh</span><span class="ref-val">€300–1200</span></div>
        </div>
      </div>
      <div class="sidebar-card">
        <h4>Add Buffer</h4>
        <ul class="tip-list">
          <li>Always add 20–30% contingency</li>
          <li>Hidden rust always costs more than expected</li>
          <li>Tools pay off over multiple builds</li>
          <li>Track actual vs. planned monthly</li>
        </ul>
      </div>
      <div class="sidebar-card">
        <h4>Related</h4>
        <ul class="tool-links">
          <li><a href="/tools/swap-checklist">M43→M50 Swap Checklist</a></li>
          <li><a href="/tools/air-suspension">Air Suspension Checklist</a></li>
          <li><a href="/build">My Build Progress</a></li>
        </ul>
      </div>
    </aside>
  </div>
</div>
</BaseLayout>

<script>
  const fields = [
    { id: 'bb-engine', label: 'Engine / Swap' },
    { id: 'bb-susp',   label: 'Suspension' },
    { id: 'bb-int',    label: 'Interior' },
    { id: 'bb-paint',  label: 'Paint / Body' },
    { id: 'bb-wheels', label: 'Wheels / Tires' },
    { id: 'bb-diag',   label: 'Diagnostics / Misc' },
    { id: 'bb-elec',   label: 'Electrical' },
    { id: 'bb-sound',  label: 'Sound Deadening' },
    { id: 'bb-tools',  label: 'Tools / Consumables' },
  ];

  function calc() {
    const items = fields
      .map(f => ({ label: f.label, val: parseFloat(document.getElementById(f.id).value) || 0 }))
      .filter(f => f.val > 0)
      .sort((a, b) => b.val - a.val);

    const total = items.reduce((s, f) => s + f.val, 0);
    const max   = items[0]?.val || 1;

    const rows = items.map(f => {
      const pct = (f.val / total * 100).toFixed(1);
      const barW = (f.val / max * 100).toFixed(1);
      return `
        <div class="result-row">
          <span class="result-label">${f.label}</span>
          <div class="result-bar-wrap">
            <div class="result-bar" style="width:${barW}%"></div>
          </div>
          <span class="result-value">€${f.val.toLocaleString()} <span class="result-pct">${pct}%</span></span>
        </div>`;
    }).join('');

    document.getElementById('budget-result').innerHTML = `
      <h4>Budget Summary</h4>
      ${rows}
      <div class="result-total">
        <span class="result-label">Total</span>
        <span class="result-value total-val">€${total.toLocaleString()}</span>
      </div>
      <p class="result-note">Add 20–30% contingency → €${Math.round(total * 1.25).toLocaleString()} realistic budget.</p>
    `;

    // Save
    const saved = {};
    fields.forEach(f => { saved[f.id] = parseFloat(document.getElementById(f.id).value) || 0; });
    localStorage.setItem('p36-build-budget', JSON.stringify(saved));
  }

  document.getElementById('calc-btn').addEventListener('click', calc);

  // Restore saved
  try {
    const s = JSON.parse(localStorage.getItem('p36-build-budget') || 'null');
    if (s) {
      fields.forEach(f => { if (s[f.id] != null) document.getElementById(f.id).value = s[f.id]; });
    }
  } catch {}
</script>

<style>
  .tool-page { max-width: var(--wide-w); margin: 0 auto; padding: 2rem 1.5rem 5rem; }

  .breadcrumb { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-dim); display: flex; gap: 0.4rem; align-items: center; margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--text-dim); transition: color 0.15s; }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { color: var(--border-mid); }

  .tool-header { margin-bottom: 2rem; }
  .tool-badge { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.15em 0.55em; border: 1px solid; display: inline-block; margin-bottom: 0.75rem; }
  .badge-plan { color: #5cb85c; border-color: rgba(92,184,92,0.35); background: rgba(92,184,92,0.06); }
  h1 { font-family: var(--font-display); font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 700; margin-bottom: 0.5rem; }
  .tool-desc { color: var(--text-mid); font-size: 0.95rem; line-height: 1.65; max-width: 56ch; }

  .tool-layout { display: grid; grid-template-columns: 1fr 280px; gap: 2.5rem; align-items: start; }
  @media (max-width: 768px) { .tool-layout { grid-template-columns: 1fr; } }

  .tool-form { background: var(--bg2); border: 1px solid var(--border); padding: 1.5rem; margin-bottom: 1.5rem; }
  .tool-form h3 { font-family: var(--font-mono); font-size: 0.72rem; color: var(--accent); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 1.25rem; }

  .field-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.25rem; }
  @media (max-width: 640px) { .field-grid { grid-template-columns: 1fr 1fr; } }
  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field-label { font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; }
  input[type="number"] { background: var(--bg3); border: 1px solid var(--border-mid); color: var(--text); font-family: var(--font-mono); font-size: 0.95rem; padding: 0.5rem 0.75rem; width: 100%; outline: none; transition: border-color 0.15s; }
  input[type="number"]:focus { border-color: var(--accent); }

  .btn-calc { background: var(--accent); color: #0d0f14; border: none; font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.06em; padding: 0.65rem 1.5rem; cursor: pointer; transition: opacity 0.15s; }
  .btn-calc:hover { opacity: 0.85; }

  .result-box { background: var(--bg2); border: 1px solid var(--border); border-left: 3px solid var(--accent); padding: 1.5rem; min-height: 120px; }
  .result-box h4 { font-family: var(--font-mono); font-size: 0.72rem; color: var(--accent); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
  .result-placeholder { color: var(--text-dim); font-size: 0.85rem; }
  .result-row { display: flex; align-items: center; gap: 0.75rem; padding: 0.4rem 0; border-bottom: 1px solid var(--border); }
  .result-label { font-size: 0.82rem; color: var(--text-mid); min-width: 130px; }
  .result-bar-wrap { flex: 1; height: 4px; background: var(--border); min-width: 40px; }
  .result-bar { height: 100%; background: var(--accent); opacity: 0.6; transition: width 0.3s; }
  .result-value { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text); min-width: 90px; text-align: right; flex-shrink: 0; }
  .result-pct { color: var(--text-dim); font-size: 0.75rem; }
  .result-total { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0 0; margin-top: 0.5rem; border-top: 1px solid var(--border-mid); }
  .total-val { font-size: 1rem; color: var(--accent); }
  .result-note { margin-top: 1rem; font-size: 0.8rem; color: var(--text-dim); line-height: 1.5; }

  .sidebar-card { background: var(--bg2); border: 1px solid var(--border); padding: 1.25rem; margin-bottom: 1rem; }
  .sidebar-card h4 { font-family: var(--font-mono); font-size: 0.68rem; color: var(--accent); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.9rem; }
  .ref-table { display: flex; flex-direction: column; gap: 0.3rem; }
  .ref-row { display: flex; justify-content: space-between; font-size: 0.8rem; }
  .ref-key { color: var(--text-mid); }
  .ref-val { font-family: var(--font-mono); color: var(--text); }
  .tip-list { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .tip-list li { font-size: 0.8rem; color: var(--text-mid); padding-left: 0.75rem; position: relative; line-height: 1.5; }
  .tip-list li::before { content: '—'; position: absolute; left: 0; color: var(--accent); }
  .tool-links { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .tool-links a { font-size: 0.82rem; color: var(--accent); transition: color 0.15s; }
  .tool-links a:hover { color: var(--text); }
</style>
