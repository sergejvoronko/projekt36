---
import BaseLayout from '../../layouts/BaseLayout.astro';
const siteBase = 'https://projekt36.com';
const breadcrumbLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',  item: siteBase },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: `${siteBase}/tools` },
    { '@type': 'ListItem', position: 3, name: 'Wheel Fitment Calculator', item: `${siteBase}/tools/wheel-fitment` },
  ],
};
const appLd = {
  '@context': 'https://schema.org', '@type': 'WebApplication',
  name: 'E36 Wheel Fitment Calculator',
  description: 'Check if your wheel and tire combination fits the BMW E36. Bolt pattern 5×120, hub bore 72.6mm.',
  url: `${siteBase}/tools/wheel-fitment`,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
};
---

<BaseLayout
  title="E36 Wheel & Tire Calculator — projekt36"
  description="Check if your wheel and tire combination fits the BMW E36. Bolt pattern 5×120, hub bore 72.6mm. Accounts for suspension height, staggered setups, and speedo deviation."
>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} slot="head" />
<script type="application/ld+json" set:html={JSON.stringify(appLd)} slot="head" />
<div class="tool-page">

  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <a href="/tools">Tools</a><span class="sep">/</span><span>Wheel & Tire Calculator</span>
  </div>

  <!-- Header -->
  <div class="tool-header">
    <div class="tool-tag">PROJEKT36 · TOOL</div>
    <h1 class="tool-title">E36 Wheel & Tire <em>Calculator</em></h1>
    <p class="tool-lead">Check if your wheel and tire setup fits the BMW E36. Bolt pattern: 5×120 · Hub bore: 72.6mm</p>
  </div>

  <div class="calc-wrap">
    <!-- Left: Controls -->
    <div class="controls-col">

      <!-- Suspension mode -->
      <div class="card">
        <div class="card-label">Suspension Setup</div>
        <div class="mode-btns" id="modeBtns">
          <button class="mode-btn" data-mode="stock">Stock Height</button>
          <button class="mode-btn active" data-mode="rolled">Lowered + Rolled</button>
          <button class="mode-btn" data-mode="aired">Air Ride</button>
        </div>
      </div>

      <!-- Diameter -->
      <div class="card">
        <div class="card-label">Wheel Diameter</div>
        <div class="slider-row">
          <span class="slider-label">Diameter</span>
          <span class="slider-val" id="diamVal">16"</span>
        </div>
        <input type="range" class="slider" id="diamSlider" min="15" max="18" step="1" value="16" />
        <div class="slider-bounds"><span>15"</span><span class="note">Most common: 16–17</span><span>18"</span></div>
      </div>

      <!-- Staggered toggle -->
      <div class="card staggered-row">
        <button class="toggle-btn" id="staggerToggle" aria-pressed="false">
          <span class="toggle-track"><span class="toggle-thumb"></span></span>
        </button>
        <span class="toggle-label">Staggered setup (different front / rear)</span>
      </div>

      <!-- Width & Offset -->
      <div class="card" id="frontCard">
        <div class="card-label" id="frontLabel">Wheel Setup</div>
        <div class="slider-row">
          <span class="slider-label">Width</span>
          <span class="slider-val" id="wFVal">8J</span>
        </div>
        <input type="range" class="slider" id="wFSlider" min="6" max="10.5" step="0.5" value="8" />
        <div class="slider-bounds"><span>6J</span><span class="note">Stock: 6.5–7.5J</span><span>10.5J</span></div>

        <div class="slider-row" style="margin-top:1rem">
          <span class="slider-label">Offset (ET)</span>
          <span class="slider-val" id="etFVal">ET30</span>
        </div>
        <input type="range" class="slider" id="etFSlider" min="5" max="50" step="1" value="30" />
        <div class="slider-bounds"><span>ET5</span><span class="note">Stock: ET42–47</span><span>ET50</span></div>

        <div style="margin-top:1rem">
          <div class="slider-label" style="margin-bottom:0.4rem">Tire Size</div>
          <select class="field-select" id="tireFSelect">
            <option value="">Select tire...</option>
          </select>
        </div>
      </div>

      <!-- Rear (staggered only) -->
      <div class="card hidden" id="rearCard">
        <div class="card-label">Rear Setup</div>
        <div class="slider-row">
          <span class="slider-label">Width</span>
          <span class="slider-val" id="wRVal">9J</span>
        </div>
        <input type="range" class="slider" id="wRSlider" min="6" max="10.5" step="0.5" value="9" />
        <div class="slider-bounds"><span>6J</span><span>10.5J</span></div>

        <div class="slider-row" style="margin-top:1rem">
          <span class="slider-label">Offset (ET)</span>
          <span class="slider-val" id="etRVal">ET25</span>
        </div>
        <input type="range" class="slider" id="etRSlider" min="5" max="50" step="1" value="25" />
        <div class="slider-bounds"><span>ET5</span><span>ET50</span></div>

        <div style="margin-top:1rem">
          <div class="slider-label" style="margin-bottom:0.4rem">Rear Tire Size</div>
          <select class="field-select" id="tireRSelect">
            <option value="">Select tire...</option>
          </select>
        </div>
      </div>

      <!-- Stock comparison -->
      <div class="card">
        <div class="card-label">Compare to Stock</div>
        <select class="field-select" id="stockModel">
          <option value="316i/318i">316i / 318i</option>
          <option value="320i/323i">320i / 323i</option>
          <option value="325i/328i" selected>325i / 328i</option>
          <option value="M3">M3</option>
        </select>
        <div class="stock-compare" id="stockCompare"></div>
      </div>

    </div>

    <!-- Right: Results -->
    <div class="results-col">

      <!-- Overall verdict -->
      <div class="card verdict-card" id="verdictCard">
        <div class="verdict-inner">
          <div class="card-label">Fitment Result</div>
          <div class="verdict-badge" id="verdictBadge">
            <span class="verdict-dot" id="verdictDot"></span>
            <span class="verdict-text" id="verdictText">—</span>
          </div>
        </div>
      </div>

      <!-- SVG Visualizations -->
      <div class="card">
        <div class="card-label">Cross-Section View</div>
        <div class="viz-grid">
          <div class="viz-wrap">
            <div class="viz-axle-label">FRONT AXLE</div>
            <svg id="svgFront" viewBox="0 0 240 180" width="100%" class="wheel-svg"></svg>
            <div class="viz-verdict" id="vFrontVerdict"></div>
          </div>
          <div class="viz-wrap">
            <div class="viz-axle-label">REAR AXLE</div>
            <svg id="svgRear" viewBox="0 0 240 180" width="100%" class="wheel-svg"></svg>
            <div class="viz-verdict" id="vRearVerdict"></div>
          </div>
        </div>
      </div>

      <!-- Measurements -->
      <div class="card">
        <div class="card-label">Detailed Measurements</div>
        <div class="measurements" id="measurements"></div>
      </div>

      <!-- Note -->
      <div class="note-block">
        <div class="note-tag">NOTE</div>
        <p>This calculator provides estimates based on common E36 fitment data. Actual clearance varies with tire brand, fender condition, and suspension geometry. Always test-fit before committing. Air ride users: fitment is calculated at show height — raise for driving clearance. Hub-centric rings required if wheel bore exceeds 72.6mm.</p>
      </div>

      <div class="tool-footer">PROJEKT 36 · E36 WHEEL CALCULATOR · 5×120 · 72.6mm HUB</div>

    </div>
  </div>
</div>
</BaseLayout>

<style>
  .tool-page {
    max-width: var(--wide-w);
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
  }

  /* Breadcrumb */
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    display: flex;
    gap: 0.4rem;
    align-items: center;
    margin-bottom: 2rem;
  }
  .breadcrumb a { color: var(--text-dim); transition: color 0.15s; }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { color: var(--border-mid); }

  /* Header */
  .tool-header { margin-bottom: 2.5rem; }
  .tool-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.22em;
    margin-bottom: 0.75rem;
  }
  .tool-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.1;
    margin-bottom: 0.6rem;
  }
  .tool-title em { font-style: italic; font-weight: 400; color: var(--accent); }
  .tool-lead { font-size: 0.9rem; color: var(--text-mid); max-width: 54ch; line-height: 1.7; }

  /* Layout */
  .calc-wrap {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 1.25rem;
    align-items: start;
  }
  @media (max-width: 920px) {
    .calc-wrap { grid-template-columns: 1fr; }
    .results-col { order: -1; }
  }

  /* Cards */
  .card {
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }
  .card:last-child { margin-bottom: 0; }
  .card-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.9rem;
  }
  .hidden { display: none !important; }

  /* Mode buttons */
  .mode-btns { display: flex; gap: 0.5rem; }
  .mode-btn {
    flex: 1;
    padding: 0.55rem 0.4rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: all 0.2s;
  }
  .mode-btn.active {
    background: rgba(212,149,42,0.1);
    border-color: rgba(212,149,42,0.4);
    color: var(--accent);
  }
  .mode-btn:hover:not(.active) { border-color: var(--border-mid); color: var(--text-mid); }

  /* Sliders */
  .slider-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.4rem;
  }
  .slider-label { font-size: 0.85rem; color: var(--text-mid); }
  .slider-val { font-family: var(--font-mono); font-size: 1rem; color: var(--accent); font-weight: 500; }
  .slider {
    width: 100%;
    height: 4px;
    appearance: none;
    background: var(--bg3);
    outline: none;
    cursor: pointer;
    accent-color: var(--accent);
  }
  .slider::-webkit-slider-thumb {
    appearance: none;
    width: 16px; height: 16px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    border: 2px solid var(--bg2);
    box-shadow: 0 0 8px rgba(212,149,42,0.3);
  }
  .slider::-moz-range-thumb {
    width: 16px; height: 16px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    border: 2px solid var(--bg2);
  }
  .slider-bounds {
    display: flex;
    justify-content: space-between;
    margin-top: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
  }
  .slider-bounds .note { color: var(--text-dim); opacity: 0.7; }

  /* Toggle */
  .staggered-row { display: flex; align-items: center; gap: 0.85rem; padding: 0.9rem 1.5rem; }
  .toggle-btn { background: none; border: none; cursor: pointer; flex-shrink: 0; }
  .toggle-track {
    display: block;
    width: 40px; height: 22px;
    border-radius: 11px;
    background: var(--bg3);
    border: 1px solid var(--border);
    position: relative;
    transition: background 0.25s, border-color 0.25s;
  }
  .toggle-btn[aria-pressed="true"] .toggle-track { background: var(--accent); border-color: var(--accent); }
  .toggle-thumb {
    display: block;
    position: absolute;
    top: 3px; left: 3px;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: var(--text-mid);
    transition: left 0.25s, background 0.25s;
  }
  .toggle-btn[aria-pressed="true"] .toggle-thumb { left: 21px; background: #0d0f14; }
  .toggle-label { font-size: 0.85rem; color: var(--text-mid); }

  /* Select */
  .field-select {
    width: 100%;
    background: var(--bg3);
    color: var(--text);
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    outline: none;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .field-select:focus { border-color: rgba(212,149,42,0.4); }

  /* Verdict */
  .verdict-card { margin-bottom: 1rem; }
  .verdict-inner { display: flex; justify-content: space-between; align-items: center; }
  .verdict-inner .card-label { margin-bottom: 0; }
  .verdict-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.85rem;
    border: 1px solid var(--border);
    background: var(--bg3);
  }
  .verdict-dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--text-dim);
  }
  .verdict-text {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-dim);
    letter-spacing: 0.08em;
  }

  /* SVG viz */
  .viz-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .viz-wrap { text-align: center; }
  .viz-axle-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
    letter-spacing: 0.15em;
    margin-bottom: 0.25rem;
  }
  .wheel-svg { display: block; }
  .viz-verdict {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    margin-top: 0.25rem;
  }

  /* Stock compare */
  .stock-compare {
    margin-top: 0.85rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.5rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.9;
  }
  .stock-compare :global(.sc-col) { }
  .stock-compare :global(.sc-label) { font-size: 0.6rem; letter-spacing: 0.1em; color: var(--text-dim); margin-bottom: 0.25rem; }
  .stock-compare :global(.sc-arrow) { color: var(--accent); font-size: 1.1rem; text-align: center; }
  .stock-compare :global(.sc-stock) { color: var(--text-dim); }
  .stock-compare :global(.sc-yours) { color: var(--text); }

  /* Measurements */
  .measurements {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 2.1;
    color: var(--text-mid);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 1.5rem;
  }
  .measurements :global(.m-label) { color: var(--text-dim); }
  .measurements :global(.m-val) { color: var(--text); }
  .measurements :global(.m-warn) { color: var(--amber); }
  .measurements :global(.m-good) { color: var(--green); }

  /* Note block */
  .note-block {
    border-left: 2px solid rgba(212,149,42,0.3);
    background: rgba(212,149,42,0.03);
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
  }
  .note-tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin-bottom: 0.4rem;
  }
  .note-block p { font-size: 0.82rem; color: var(--text-dim); line-height: 1.7; }

  /* Footer */
  .tool-footer {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-align: center;
    padding: 0.5rem 0;
  }
</style>

<script>
// ── E36 DATA ──────────────────────────────────────────────────────────
const E36 = {
  boltPattern: '5×120',
  hubBore: 72.6,
  stock: {
    '316i/318i': { front: { w: 6.5, d: 15, et: 42 }, rear: { w: 6.5, d: 15, et: 42 }, tire: '195/65R15' },
    '320i/323i': { front: { w: 7,   d: 15, et: 47 }, rear: { w: 7,   d: 15, et: 47 }, tire: '205/60R15' },
    '325i/328i': { front: { w: 7,   d: 15, et: 47 }, rear: { w: 7,   d: 15, et: 47 }, tire: '205/60R15' },
    'M3':        { front: { w: 7.5, d: 17, et: 41 }, rear: { w: 8.5, d: 17, et: 41 }, tire: '235/40R17' },
  },
  limits: {
    stock:  { front: { inner: 90, outer: 25 }, rear: { inner: 95, outer: 20 } },
    rolled: { front: { inner: 90, outer: 10 }, rear: { inner: 95, outer:  5 } },
    aired:  { front: { inner: 90, outer: -5 }, rear: { inner: 95, outer:-15 } },
  },
};

const TIRES = {
  15: ['185/65','195/65','195/60','205/60','205/55','215/55'],
  16: ['195/55','205/50','205/55','215/45','215/50','225/45','225/50'],
  17: ['205/45','205/40','215/40','215/45','225/40','225/45','235/40','245/35'],
  18: ['205/35','215/35','215/40','225/35','225/40','235/35','245/35'],
};

// ── STATE ──────────────────────────────────────────────────────────────
let state = {
  suspension: 'rolled',
  diameter: 16,
  widthF: 8, etF: 30, tireF: '',
  widthR: 9, etR: 25, tireR: '',
  staggered: false,
  stockModel: '325i/328i',
};

// ── UTILS ──────────────────────────────────────────────────────────────
function geo(wInch, et) {
  const wMM = wInch * 25.4;
  return { wMM, inner: wMM / 2 + et, outer: wMM / 2 - et };
}

function verdict(g, susp, pos) {
  const lim = E36.limits[susp][pos];
  let status = 'good'; const issues = [];
  if (g.inner > lim.inner + 10) { issues.push('Inner lip may contact strut/spring'); status = 'bad'; }
  else if (g.inner > lim.inner) { issues.push('Tight inner clearance — measure carefully'); status = 'warn'; }
  if (g.outer > lim.outer + 15) { issues.push('Significant poke — likely illegal in EU'); if (status !== 'bad') status = 'bad'; }
  else if (g.outer > lim.outer) { issues.push('Slight poke — may need fender rolling'); if (status === 'good') status = 'warn'; }
  return { status, issues };
}

function parseTire(s) {
  const m = s.match(/(\d+)\/(\d+)/); if (!m) return null;
  const sw = +m[1] * (+m[2] / 100);
  return { width: +m[1], aspect: +m[2], sidewall: sw };
}

function tireDiam(s, dInch) {
  const t = parseTire(s); if (!t) return null;
  return t.sidewall * 2 + dInch * 25.4;
}

const statusColor = { good: '#5cb85c', warn: '#e8a83e', bad: '#d9534f' };
const statusLabel = { good: 'FITS', warn: 'TIGHT', bad: 'NO FIT' };

// ── SVG DRAW ──────────────────────────────────────────────────────────
function drawSVG(svgEl, g, v, susp, pos, diam, wInch, et, tireStr) {
  const W = 240, H = 180, cx = W / 2;
  const scale = 0.65;
  const rimTop = 28, rimBot = H - 18;
  const rimH = rimBot - rimTop;
  const col = statusColor[v.status];
  const lim = E36.limits[susp][pos];

  const innerX = cx - g.inner * scale;
  const outerX = cx + g.outer * scale;
  const fenderX = cx + lim.outer * scale;

  const tireData = tireStr ? parseTire(tireStr) : null;
  const tireW = tireData ? tireData.sidewall * scale * 0.4 : 0;

  const ns = 'http://www.w3.org/2000/svg';
  function el(tag, attrs, text) {
    const e = document.createElementNS(ns, tag);
    for (const [k, v] of Object.entries(attrs)) e.setAttribute(k, v);
    if (text !== undefined) e.textContent = text;
    return e;
  }

  svgEl.innerHTML = '';

  // Background
  svgEl.appendChild(el('rect', { x: 0, y: 0, width: W, height: H, fill: '#0d1017' }));

  // Fender line
  svgEl.appendChild(el('line', { x1: fenderX, y1: rimTop - 12, x2: fenderX, y2: rimBot + 6, stroke: '#444', 'stroke-width': 1, 'stroke-dasharray': '4,3' }));
  svgEl.appendChild(el('text', { x: fenderX, y: rimTop - 15, 'text-anchor': 'middle', fill: '#444', 'font-size': 7, 'font-family': 'IBM Plex Mono,monospace' }, 'FENDER'));

  // Hub center
  svgEl.appendChild(el('line', { x1: cx, y1: rimTop, x2: cx, y2: rimBot, stroke: `${col}33`, 'stroke-width': 1, 'stroke-dasharray': '2,4' }));

  // Tire outline
  if (tireData) {
    svgEl.appendChild(el('rect', { x: innerX - tireW, y: rimTop - 5, width: outerX - innerX + tireW * 2, height: rimH + 10, rx: 5, fill: 'none', stroke: '#33333355', 'stroke-width': 2 }));
  }

  // Wheel barrel fill
  svgEl.appendChild(el('rect', { x: innerX, y: rimTop, width: outerX - innerX, height: rimH, rx: 2, fill: `${col}0a`, stroke: col, 'stroke-width': 1.5 }));

  // Inner / outer lips
  svgEl.appendChild(el('line', { x1: innerX, y1: rimTop, x2: innerX, y2: rimBot, stroke: col, 'stroke-width': 2 }));
  svgEl.appendChild(el('line', { x1: outerX, y1: rimTop, x2: outerX, y2: rimBot, stroke: col, 'stroke-width': 2 }));

  // Spokes hint
  [[cx, rimTop+10, innerX+5, rimTop+5],[cx, rimBot-10, innerX+5, rimBot-5],
   [cx, rimTop+10, outerX-5, rimTop+5],[cx, rimBot-10, outerX-5, rimBot-5]].forEach(([x1,y1,x2,y2]) => {
    svgEl.appendChild(el('line', { x1, y1, x2, y2, stroke: `${col}44`, 'stroke-width': 0.8 }));
  });

  // Hub dot
  svgEl.appendChild(el('circle', { cx, cy: H / 2, r: 3, fill: '#d4952a', opacity: 0.7 }));

  // ET label
  svgEl.appendChild(el('line', { x1: cx, y1: rimBot + 8, x2: outerX, y2: rimBot + 8, stroke: '#555', 'stroke-width': 0.5 }));
  svgEl.appendChild(el('text', { x: (cx + outerX) / 2, y: rimBot + 17, 'text-anchor': 'middle', fill: '#555', 'font-size': 7, 'font-family': 'IBM Plex Mono,monospace' }, `ET${et}`));

  // Spec label
  svgEl.appendChild(el('text', { x: (innerX + outerX) / 2, y: H / 2 + 4, 'text-anchor': 'middle', fill: `${col}99`, 'font-size': 9, 'font-family': 'IBM Plex Mono,monospace', 'font-weight': 500 }, `${wInch}J×${diam}`));
}

// ── RENDER ──────────────────────────────────────────────────────────────
function render() {
  const { suspension, diameter, widthF, etF, tireF, staggered, stockModel } = state;
  const widthR = staggered ? state.widthR : widthF;
  const etR    = staggered ? state.etR    : etF;
  const tireR  = staggered ? state.tireR  : tireF;

  const gF = geo(widthF, etF);
  const gR = geo(widthR, etR);
  const vF = verdict(gF, suspension, 'front');
  const vR = verdict(gR, suspension, 'rear');
  const overall = vF.status === 'bad' || vR.status === 'bad' ? 'bad'
                : vF.status === 'warn' || vR.status === 'warn' ? 'warn' : 'good';

  // Verdict badge
  const dot = document.getElementById('verdictDot');
  const txt = document.getElementById('verdictText');
  const col = statusColor[overall];
  dot.style.background = col;
  dot.style.boxShadow = `0 0 8px ${col}66`;
  txt.textContent = statusLabel[overall];
  txt.style.color = col;
  document.getElementById('verdictCard').style.borderColor = `${col}33`;

  // SVGs
  drawSVG(document.getElementById('svgFront'), gF, vF, suspension, 'front', diameter, widthF, etF, tireF);
  drawSVG(document.getElementById('svgRear'),  gR, vR, suspension, 'rear',  diameter, widthR, etR, tireR);

  // Verdict labels
  ['Front','Rear'].forEach((side, i) => {
    const v = i === 0 ? vF : vR;
    const el = document.getElementById(`v${side}Verdict`);
    el.textContent = statusLabel[v.status];
    el.style.color = statusColor[v.status];
    if (v.issues.length) el.title = v.issues.join(' | ');
  });

  // Measurements
  const dF = tireF ? tireDiam(tireF, diameter) : null;
  const dR = tireR ? tireDiam(tireR, diameter) : null;
  const stock = E36.stock[stockModel];
  const dStock = stock ? tireDiam(stock.tire.replace(/R\d+/, ''), +stock.tire.match(/R(\d+)/)?.[1]) : null;
  const speedoDiff = dF && dStock ? ((dF / dStock - 1) * 100) : null;

  const mEl = document.getElementById('measurements');
  mEl.innerHTML = `
    <span class="m-label">Front spec:</span><span class="m-val">${widthF}J×${diameter} ET${etF}${tireF ? ' + ' + tireF + 'R' + diameter : ''}</span>
    <span class="m-label">Rear spec:</span><span class="m-val">${widthR}J×${diameter} ET${etR}${tireR ? ' + ' + tireR + 'R' + diameter : ''}</span>
    <span class="m-label">Front inner/outer:</span><span class="m-val">${gF.inner.toFixed(0)}mm / ${gF.outer.toFixed(0)}mm</span>
    <span class="m-label">Rear inner/outer:</span><span class="m-val">${gR.inner.toFixed(0)}mm / ${gR.outer.toFixed(0)}mm</span>
    ${dF ? `<span class="m-label">Tire diameter:</span><span class="m-val">${dF.toFixed(0)}mm (${(dF/25.4).toFixed(1)}")</span>` : ''}
    ${speedoDiff !== null ? `<span class="m-label">Speedo vs stock:</span><span class="${Math.abs(speedoDiff) > 3 ? 'm-warn' : 'm-good'}">${speedoDiff > 0 ? '+' : ''}${speedoDiff.toFixed(1)}%${Math.abs(speedoDiff) > 3 ? ' ⚠ recalibrate' : ''}</span>` : ''}
  `;

  // Stock comparison
  const sc = document.getElementById('stockCompare');
  if (stock) {
    sc.innerHTML = `
      <div class="sc-col">
        <div class="sc-label">STOCK</div>
        <div class="sc-stock">F: ${stock.front.w}J×${stock.front.d} ET${stock.front.et}</div>
        <div class="sc-stock">R: ${stock.rear.w}J×${stock.rear.d} ET${stock.rear.et}</div>
        <div class="sc-stock" style="font-size:0.65rem;opacity:0.5">${stock.tire}</div>
      </div>
      <div class="sc-arrow">→</div>
      <div class="sc-col">
        <div class="sc-label" style="color:var(--accent)">YOURS</div>
        <div class="sc-yours">F: ${widthF}J×${diameter} ET${etF}</div>
        <div class="sc-yours">R: ${widthR}J×${diameter} ET${etR}</div>
        ${tireF ? `<div class="sc-yours" style="font-size:0.65rem;opacity:0.7">${tireF}R${diameter}${staggered && tireR ? ' / ' + tireR + 'R' + diameter : ''}</div>` : ''}
      </div>
    `;
  }
}

// ── TIRE DROPDOWN ──────────────────────────────────────────────────────
function populateTires() {
  const opts = TIRES[state.diameter] || [];
  ['tireFSelect','tireRSelect'].forEach(id => {
    const sel = document.getElementById(id);
    const cur = sel.value;
    sel.innerHTML = '<option value="">Select tire...</option>' +
      opts.map(t => `<option value="${t}" ${t === cur ? 'selected' : ''}>${t}R${state.diameter}</option>`).join('');
  });
}

// ── INIT ──────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {

  // Suspension buttons
  document.getElementById('modeBtns').addEventListener('click', e => {
    const btn = e.target.closest('.mode-btn'); if (!btn) return;
    document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    state.suspension = btn.dataset.mode;
    render();
  });

  // Slider helpers
  function bindSlider(sliderId, valId, fmt, key) {
    const s = document.getElementById(sliderId);
    const v = document.getElementById(valId);
    s.addEventListener('input', () => {
      state[key] = +s.value; v.textContent = fmt(+s.value); render();
    });
    v.textContent = fmt(+s.value);
  }
  bindSlider('diamSlider', 'diamVal', v => `${v}"`, 'diameter');
  bindSlider('wFSlider',   'wFVal',   v => `${v}J`, 'widthF');
  bindSlider('etFSlider',  'etFVal',  v => `ET${v}`, 'etF');
  bindSlider('wRSlider',   'wRVal',   v => `${v}J`, 'widthR');
  bindSlider('etRSlider',  'etRVal',  v => `ET${v}`, 'etR');

  // Diameter change: repopulate tires
  document.getElementById('diamSlider').addEventListener('input', () => populateTires());

  // Tire selects
  document.getElementById('tireFSelect').addEventListener('change', e => { state.tireF = e.target.value; render(); });
  document.getElementById('tireRSelect').addEventListener('change', e => { state.tireR = e.target.value; render(); });

  // Staggered toggle
  const tog = document.getElementById('staggerToggle');
  tog.addEventListener('click', () => {
    state.staggered = !state.staggered;
    tog.setAttribute('aria-pressed', state.staggered);
    document.getElementById('rearCard').classList.toggle('hidden', !state.staggered);
    document.getElementById('frontLabel').textContent = state.staggered ? 'Front Setup' : 'Wheel Setup';
    render();
  });

  // Stock model
  document.getElementById('stockModel').addEventListener('change', e => { state.stockModel = e.target.value; render(); });

  populateTires();
  render();
});
</script>
