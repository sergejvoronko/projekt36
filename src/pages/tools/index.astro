---
import BaseLayout from '../../layouts/BaseLayout.astro';
const tools = [
  { title: 'Wheel Fitment Calculator', badge: 'Calculator', desc: 'Compare wheel width, ET, tire size, and spacers.', href: '/tools/wheel-fitment', ready: true },
  { title: 'Tire Size Compare',        badge: 'Calculator', desc: 'Compare two tire sizes — diameter, sidewall, speedo diff.', href: '/tools/tire-compare', ready: true },
  { title: 'Offset & Spacer Tool',     badge: 'Calculator', desc: 'See how spacers and offset changes affect stance.', href: '/tools/offset-spacer', ready: true },
  { title: 'M43 → M50 Swap Checklist',badge: 'Swap',       desc: 'Parts, wiring, cooling, exhaust, first startup.', href: '/tools/swap-checklist', ready: true },
  { title: 'Build Budget Planner',     badge: 'Planning',   desc: 'Estimate costs across all build modules.', href: '/tools/build-budget', ready: true },
  { title: 'Build Progress Tracker',   badge: 'Planning',   desc: 'Break your build into modules, track status.', href: '/tools/progress-tracker', ready: false },
  { title: 'Electric Windows Retrofit',badge: 'Retrofit',   desc: 'Switches, regulators, wiring, install progress.', href: '/tools/electric-windows-retrofit', ready: false },
  { title: 'Climate Control Retrofit', badge: 'Retrofit',   desc: 'Stages and parts for climate control conversion.', href: '/tools/climate-control-retrofit', ready: false },
  { title: 'Sound Deadening Planner',  badge: 'Retrofit',   desc: 'Floor, trunk, doors, firewall, rear sections.', href: '/tools/sound-deadening', ready: false },
  { title: 'Air Suspension Checklist', badge: 'Suspension', desc: 'Management, bags, compressor, tank, lines, wiring.', href: '/tools/air-suspension', ready: true },
  { title: 'INPA Check Log',           badge: 'Diagnostics',desc: 'Store notes from scans, active and resolved faults.', href: '/tools/inpa-log', ready: false },
  { title: 'Restoration Checklist',    badge: 'Planning',   desc: 'Rust, trim, paint, interior, electrical, engine.', href: '/tools/restoration-checklist', ready: false },
];
---

<BaseLayout title="BMW E36 Tools &amp; Calculators — projekt36" description="Practical calculators, checklists, and planners for BMW E36 owners.">
  <section class="tools-hero">
    <div class="tools-hero-img" aria-hidden="true">
      <img src="/images/blueprint-m52-anatomy.webp" alt="" width="1200" height="600" loading="eager" decoding="async" />
      <div class="tools-hero-overlay"></div>
    </div>
    <div class="inner tools-hero-inner">
      <div class="page-tag">PROJEKT36 · TOOLS &amp; CALCULATORS</div>
      <h1 class="hero-title">E36 <em>Tools</em></h1>
      <p class="hero-sub">Practical calculators, checklists, and planners built around real E36 work — fitment, swaps, retrofits, and build planning.</p>
    </div>
  </section>

  <section class="tools-section">
    <div class="inner">
      <div class="tools-grid">
        {tools.filter(t => t.ready).map(t => (
          <a href={t.href} class="tool-card">
            <div class="tool-badge">{t.badge}</div>
            <h3 class="tool-title">{t.title}</h3>
            <p class="tool-desc">{t.desc}</p>
            <span class="tool-cta">Open →</span>
          </a>
        ))}
      </div>

      {tools.some(t => !t.ready) && (
        <div class="coming-soon-section">
          <div class="coming-soon-header">
            <span class="coming-soon-label">In development</span>
          </div>
          <div class="tools-grid soon-grid">
            {tools.filter(t => !t.ready).map(t => (
              <div class="tool-card soon">
                <div class="tool-badge">{t.badge}</div>
                <h3 class="tool-title">{t.title}</h3>
                <p class="tool-desc">{t.desc}</p>
                <span class="tool-soon">Coming soon</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .tools-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    min-height: 320px;
    display: flex;
    align-items: flex-end;
  }
  .tools-hero-img {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .tools-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.35) saturate(0.6);
  }
  .tools-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(19,23,32,1) 0%, rgba(19,23,32,0.55) 60%, rgba(19,23,32,0.3) 100%);
  }
  .inner { max-width: var(--wide-w); margin: 0 auto; }
  .tools-hero-inner {
    position: relative;
    z-index: 1;
    padding: 5rem 1.5rem 3rem;
    width: 100%;
  }
  .page-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.05;
  }
  .hero-title em { font-style: italic; font-weight: 400; color: var(--accent); }
  .hero-sub { font-size: 0.95rem; color: var(--text-mid); max-width: 56ch; line-height: 1.75; }

  .tools-section { padding: 3rem 1.5rem 5rem; }
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; }

  .tool-card {
    display: block; padding: 1.5rem;
    background: var(--bg2); border: 1px solid var(--border);
    border-left: 3px solid transparent;
    text-decoration: none;
    transition: border-color 0.15s, border-left-color 0.15s;
  }
  .tool-card:not(.soon):hover { border-left-color: var(--accent); border-color: var(--border-mid); }
  .tool-card.soon { opacity: 0.45; cursor: default; }

  .coming-soon-section { margin-top: 3rem; }
  .coming-soon-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .coming-soon-header::before,
  .coming-soon-header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .coming-soon-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    white-space: nowrap;
  }

  .tool-badge {
    display: inline-block; font-family: var(--font-mono); font-size: 0.62rem;
    font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); background: var(--accent-dim);
    border: 1px solid rgba(212,149,42,0.25); padding: 0.18em 0.55em;
    margin-bottom: 0.8rem;
  }
  .tool-title { font-size: 0.95rem; font-weight: 600; color: var(--text); margin-bottom: 0.45rem; }
  .tool-card:not(.soon):hover .tool-title { color: var(--accent); }
  .tool-desc { font-size: 0.82rem; color: var(--text-mid); line-height: 1.55; margin-bottom: 0.75rem; }
  .tool-cta { font-family: var(--font-mono); font-size: 0.7rem; color: var(--accent); opacity: 0; transition: opacity 0.15s; }
  .tool-card:hover .tool-cta { opacity: 1; }
  .tool-soon { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-dim); }
</style>
