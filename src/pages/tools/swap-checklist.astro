---
import BaseLayout from '../../layouts/BaseLayout.astro';

const groups = [
  {
    title: '1 — Donor Engine',
    items: [
      { text: 'Source M50/M52 engine — confirm variant (M50B20, M50B25, M52B28)', note: 'Check for VANOS rattle, timing chain stretch, oil leaks at valve cover and oil pan' },
      { text: 'Compression test all cylinders', note: 'Target: 170–210 psi, max 10% variance between cylinders' },
      { text: 'Collect matching ECU (DME) and complete engine wiring loom' },
      { text: 'Get donor MAF sensor, intake boot, and throttle body' },
    ]
  },
  {
    title: '2 — Removal & Preparation',
    items: [
      { text: 'Remove M43 engine and gearbox', note: 'Label and bag all connectors, hoses, and bolts' },
      { text: 'Inspect engine bay — clean, rust-treat, paint if needed' },
      { text: 'Check subframe and engine mount condition' },
      { text: 'Verify clutch and flywheel compatibility (M50 vs M43 input shaft)' },
    ]
  },
  {
    title: '3 — Engine Mounts & Accessories',
    items: [
      { text: 'Confirm engine mount brackets match (E36 M50 mounts)', note: 'M43 mounts differ — check Lemförder / Meyle references' },
      { text: 'Fit power steering pump and A/C compressor brackets' },
      { text: 'Install alternator and belt routing for M50 accessory drive' },
      { text: 'Check driveshaft length and spline count compatibility' },
    ]
  },
  {
    title: '4 — Cooling System',
    items: [
      { text: 'Fit M50 radiator hoses (upper/lower differ from M43)', note: 'Consider full aluminum radiator upgrade' },
      { text: 'Install thermostat and water pump (M50-specific)' },
      { text: 'Replace expansion tank and bleed screw', note: 'E36 plastic tanks crack — always replace preventively' },
      { text: 'Verify heater core hose routing and connections' },
    ]
  },
  {
    title: '5 — Wiring & ECU',
    items: [
      { text: 'Route M50 engine harness through firewall', note: 'Use existing M43 grommet — may need trimming' },
      { text: 'Connect DME, MAF, TPS, CPS, and all sensor plugs' },
      { text: 'Wire fuel injectors and coil packs' },
      { text: 'Connect EWS (immobilizer) — may need alignment or bypass' },
    ]
  },
  {
    title: '6 — Exhaust & First Startup',
    items: [
      { text: 'Fit exhaust manifold and downpipe (M50 flange pattern)', note: 'Check lambda sensor placement and wiring' },
      { text: 'Connect exhaust — verify no leaks at manifold gasket' },
      { text: 'Fill fluids: coolant, oil, power steering, transmission' },
      { text: 'First start — check for leaks, listen for noises, run INPA', note: 'Idle should settle to ~700 RPM after warm-up' },
    ]
  },
];

const total = groups.reduce((s, g) => s + g.items.length, 0);
const siteBase = 'https://projekt36.com';
const breadcrumbLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',  item: siteBase },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: `${siteBase}/tools` },
    { '@type': 'ListItem', position: 3, name: 'M43 → M50 Swap Checklist', item: `${siteBase}/tools/swap-checklist` },
  ],
};
const appLd = {
  '@context': 'https://schema.org', '@type': 'WebApplication',
  name: 'M43 → M50 Swap Checklist',
  description: 'Track every stage of the M43 to M50 engine swap — from sourcing the donor to first startup.',
  url: `${siteBase}/tools/swap-checklist`,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
};
---

<BaseLayout
  title="M43 → M50 Swap Checklist — projekt36"
  description="Track every stage of the M43 to M50 engine swap — from sourcing the donor to first startup."
>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} slot="head" />
<script type="application/ld+json" set:html={JSON.stringify(appLd)} slot="head" />
<div class="tool-page">
  <div class="breadcrumb">
    <a href="/tools">Tools</a>
    <span class="sep">/</span>
    <span>M43 → M50 Swap Checklist</span>
  </div>

  <div class="tool-header">
    <span class="tool-badge badge-swap">Swap</span>
    <h1>M43 → M50 Swap Checklist</h1>
    <p class="tool-desc">Track every stage of the engine swap — from sourcing the donor M50/M52 to first startup. Progress saves automatically.</p>
  </div>

  <div class="progress-wrap">
    <div class="progress-header">
      <span class="progress-label">Swap progress</span>
      <span class="progress-count" id="swap-pct">0 / {total}</span>
    </div>
    <div class="progress-track">
      <div class="progress-fill" id="swap-bar" style="width:0%"></div>
    </div>
  </div>

  <div class="tool-layout">
    <div class="checklist-wrap">
      {groups.map((g, gi) => (
        <div class="checklist-group">
          <h3 class="group-title">{g.title}</h3>
          {g.items.map((item, ii) => (
            <label class="check-item" id={`item-${gi}-${ii}`}>
              <input type="checkbox" data-id={`${gi}-${ii}`} onchange="updateProgress()" />
              <div class="check-content">
                <span class="check-text">{item.text}</span>
                {item.note && <span class="check-note">{item.note}</span>}
              </div>
            </label>
          ))}
        </div>
      ))}
    </div>

    <aside class="tool-sidebar">
      <div class="sidebar-card">
        <h4>Key Part Numbers</h4>
        <div class="pn-list">
          <div class="pn-row"><span class="pn-key">Mount L</span><span class="pn-val">22 11 1 094 813</span></div>
          <div class="pn-row"><span class="pn-key">Mount R</span><span class="pn-val">22 11 1 094 814</span></div>
          <div class="pn-row"><span class="pn-key">Trans mount</span><span class="pn-val">22 31 1 094 916</span></div>
          <div class="pn-row"><span class="pn-key">Exp. tank</span><span class="pn-val">17 11 1 723 520</span></div>
          <div class="pn-row"><span class="pn-key">Thermostat</span><span class="pn-val">11 53 1 722 531</span></div>
          <div class="pn-src">Source: realoem.com</div>
        </div>
      </div>
      <div class="sidebar-card">
        <h4>Related</h4>
        <ul class="tool-links">
          <li><a href="/tools/build-budget">Build Budget Planner</a></li>
          <li><a href="/tools/air-suspension">Air Suspension Checklist</a></li>
          <li><a href="/guides/e36-obd1-diagnostic-setup">Diagnostic Setup Guide</a></li>
          <li><a href="/guides/m43-to-m50-complete-parts-list">M43→M50 Parts List</a></li>
        </ul>
      </div>
      <button class="btn-reset" onclick="resetChecklist()">Reset checklist</button>
    </aside>
  </div>

  <div class="tool-explainer">
    <h2>About the M43 to M50 swap</h2>
    <p>
      Swapping the single-cam M43 for a twin-cam M50 or M52 is the most common E36 engine upgrade.
      The M43 and M50 share the same block dimensions and mounting points, which makes this a
      straightforward swap for a four-cylinder car. The M50B25 (170 hp) and M52B28 (193 hp) are
      the most popular choices — both fit without chassis modification.
    </p>
    <p>
      The main complexity is electrical. The M50/M52 uses a Siemens DME (MS41/MS42) with a
      dedicated engine loom that does not share connectors with the M43 setup. You need the complete
      loom from the donor car, plus the matching ECU (DME) and instrument cluster for correct
      speedometer and rev counter calibration. The M50 also brings EWS (engine immobiliser) from
      1994 onwards — the EWS module and key must match the DME.
    </p>
    <p>
      Check all items before first startup: coolant system bleed (the M50 bleeds from the expansion
      tank, not the thermostat housing), clutch pedal travel, and engine bay wiring routing. Allow
      two to three weekends for a first-time swap in a clean shell with all parts on hand.
    </p>
  </div>
</div>
</BaseLayout>

<script define:vars={{ total }}>
  const SLUG = 'p36-swap-checklist';

  function updateProgress() {
    const boxes = document.querySelectorAll('input[type=checkbox]');
    const done  = [...boxes].filter(b => b.checked).length;
    document.getElementById('swap-pct').textContent = `${done} / ${total}`;
    document.getElementById('swap-bar').style.width = `${(done / total * 100).toFixed(1)}%`;

    boxes.forEach(cb => {
      cb.closest('.check-item')?.classList.toggle('done', cb.checked);
    });

    const state = [...boxes].map(b => b.checked);
    localStorage.setItem(SLUG, JSON.stringify(state));
  }

  function resetChecklist() {
    if (!confirm('Reset all items?')) return;
    document.querySelectorAll('input[type=checkbox]').forEach(b => { b.checked = false; });
    localStorage.removeItem(SLUG);
    updateProgress();
  }

  window.updateProgress  = updateProgress;
  window.resetChecklist  = resetChecklist;

  // Restore
  try {
    const saved = JSON.parse(localStorage.getItem(SLUG) || 'null');
    if (saved) {
      document.querySelectorAll('input[type=checkbox]').forEach((b, i) => {
        b.checked = !!saved[i];
      });
      updateProgress();
    }
  } catch {}
</script>

<style>
  .tool-page { max-width: var(--wide-w); margin: 0 auto; padding: 2rem 1.5rem 5rem; }

  .breadcrumb { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-dim); display: flex; gap: 0.4rem; align-items: center; margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--text-dim); transition: color 0.15s; }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { color: var(--border-mid); }

  .tool-header { margin-bottom: 1.5rem; }
  .tool-badge { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.15em 0.55em; border: 1px solid; display: inline-block; margin-bottom: 0.75rem; }
  .badge-swap { color: #e8a83e; border-color: rgba(232,168,62,0.35); background: rgba(232,168,62,0.06); }
  h1 { font-family: var(--font-display); font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 700; margin-bottom: 0.5rem; }
  .tool-desc { color: var(--text-mid); font-size: 0.95rem; line-height: 1.65; max-width: 56ch; }

  .progress-wrap { background: var(--bg2); border: 1px solid var(--border); padding: 1.25rem 1.5rem; margin-bottom: 2rem; }
  .progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
  .progress-label { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em; }
  .progress-count { font-family: var(--font-mono); font-size: 0.85rem; color: var(--accent); }
  .progress-track { height: 6px; background: var(--border); position: relative; }
  .progress-fill { height: 100%; background: var(--accent); transition: width 0.3s ease; }

  .tool-layout { display: grid; grid-template-columns: 1fr 260px; gap: 2.5rem; align-items: start; }
  @media (max-width: 768px) { .tool-layout { grid-template-columns: 1fr; } }

  .checklist-group { margin-bottom: 2rem; }
  .group-title { font-family: var(--font-mono); font-size: 0.72rem; color: var(--accent); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }

  .check-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.12s;
  }
  .check-item:hover { background: var(--bg2); margin: 0 -0.75rem; padding-left: 0.75rem; padding-right: 0.75rem; }
  .check-item:last-child { border-bottom: none; }
  .check-item input[type=checkbox] {
    width: 16px; height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: var(--accent);
    cursor: pointer;
  }
  .check-content { display: flex; flex-direction: column; gap: 0.2rem; }
  .check-text { font-size: 0.9rem; color: var(--text); line-height: 1.5; transition: color 0.15s; }
  .check-note { font-size: 0.78rem; color: var(--text-dim); line-height: 1.45; font-style: italic; }
  .check-item.done .check-text { color: var(--text-dim); text-decoration: line-through; }

  .sidebar-card { background: var(--bg2); border: 1px solid var(--border); padding: 1.25rem; margin-bottom: 1rem; }
  .sidebar-card h4 { font-family: var(--font-mono); font-size: 0.68rem; color: var(--accent); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.9rem; }
  .pn-list { display: flex; flex-direction: column; gap: 0.35rem; }
  .pn-row { display: flex; justify-content: space-between; gap: 0.5rem; }
  .pn-key { font-size: 0.78rem; color: var(--text-dim); }
  .pn-val { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text); text-align: right; }
  .pn-src { font-size: 0.68rem; color: var(--text-dim); margin-top: 0.5rem; }
  .tool-links { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .tool-links a { font-size: 0.82rem; color: var(--accent); transition: color 0.15s; }
  .tool-links a:hover { color: var(--text); }
  .btn-reset { width: 100%; background: transparent; border: 1px solid var(--border-mid); color: var(--text-dim); font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.06em; padding: 0.55rem; cursor: pointer; transition: border-color 0.15s, color 0.15s; }
  .btn-reset:hover { border-color: var(--red); color: var(--red); }

  .tool-explainer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .tool-explainer h2 {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.25rem;
  }
  .tool-explainer p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.75; }
  .tool-explainer strong { color: var(--text); font-weight: 600; }
</style>
