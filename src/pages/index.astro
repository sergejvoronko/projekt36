---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="projekt36 — BMW E36 Build Journal & Tools">

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-car" aria-hidden="true">
      <img src="/images/IMG_0511 (1).jpg" alt="" width="900" height="400" />
    </div>
    <div class="hero-inner">
      <div class="hero-label">
        <span>PROJEKT36</span>
        <span class="hero-dot">·</span>
        <span>BUILD JOURNAL</span>
        <span class="hero-dot">·</span>
        <span>RETROFIT GUIDES</span>
        <span class="hero-dot">·</span>
        <span>E36 TOOLS</span>
      </div>
      <h1 class="hero-title">
        316i <em class="hero-em">becomes</em><br>something more
      </h1>
      <p class="hero-lead">
        One BMW E36 Compact. Documented from the first fault code to final drive.
        Engine swap, wiring, suspension, sound, paint — eleven chapters, one transformation.
      </p>
      <div class="hero-ctas">
        <a href="/build" class="btn-primary">Build Journal →</a>
        <a href="/tools" class="btn-outline">Explore Tools</a>
        <a href="/guides" class="btn-outline">Guides</a>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section class="stats-strip">
    <div class="stats-inner">
      <div class="stat">
        <span class="stat-num">67</span>
        <span class="stat-label">Articles</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">2.8</span>
        <span class="stat-label">Years in progress</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">126</span>
        <span class="stat-label">Parts documented</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">11</span>
        <span class="stat-label">Build chapters</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">40</span>
        <span class="stat-label">Retrofit guides</span>
      </div>
    </div>
  </section>

  <!-- ═══ ELEVEN CHAPTERS ═══ -->
  <section class="section chapters-section">
    <div class="section-inner">
      <div class="chapters-layout">
        <div class="chapters-content">
          <div class="section-tag">The build narrative</div>
          <h2 class="section-title">ELEVEN CHAPTERS.<br><em class="accent-em">ONE TRANSFORMATION.</em></h2>
          <p class="section-body">
            From a stock 316i Compact with a tired M43 to a proper driver's car with an M50 under the bonnet.
            Every decision documented — what worked, what failed, what it cost.
          </p>
          <a href="/build" class="btn-primary">Start reading →</a>
        </div>
        <div class="chapters-meta">
          <div class="chapter-list">
            {[
              'Teardown & diagnosis',
              'Engine pull — M43 out',
              'Bay prep & rust work',
              'M50 conversion',
              'Cooling & ancillaries',
              'Wiring & ECU',
              'Suspension rebuild',
              'Interior & sound',
              'Paint & body',
              'Wheels & fitment',
              'First drive & tuning',
            ].map((ch, i) => (
              <div class="chapter-row">
                <span class="chapter-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="chapter-name">{ch}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WEAK POINTS ═══ -->
  <section class="section alt weak-section">
    <div class="section-inner">
      <div class="section-tag">Know your car</div>
      <h2 class="section-title">EVERY E36's <em class="accent-em">WEAK POINTS</em></h2>
      <p class="section-sub">The recurring failures every E36 owner will face — and how to get ahead of them.</p>
      <div class="weak-grid">
        {[
          { title: 'Cooling system',    desc: 'Plastic thermostat housing, expansion tank, and radiator all crack with age. Replace preventively.' },
          { title: 'Rear subframe',     desc: 'Subframe mounts tear through the chassis on high-mileage or lowered cars. Weld before it cracks.' },
          { title: 'DISA valve',        desc: 'M52/M54 only. The plastic paddle fails, causing rough idle and power loss. Cheap fix, high impact.' },
          { title: 'Window regulators', desc: 'Plastic clips snap on all doors. Replace with metal-clip units or budget for repeated fixes.' },
          { title: 'Rear trailing arms', desc: 'Bushings collapse, causing vague rear handling. Polyurethane or pillow-ball arms fix this properly.' },
          { title: 'Electrical gremlins', desc: 'Door loom wears through the grommet, killing windows and locks. Reroute and sleeve the harness.' },
        ].map(wp => (
          <div class="weak-card">
            <h3 class="weak-title">{wp.title}</h3>
            <p class="weak-desc">{wp.desc}</p>
          </div>
        ))}
      </div>
      <div class="section-more">
        <a href="/guides" class="btn-outline">All guides →</a>
      </div>
    </div>
  </section>

  <!-- ═══ TALK TO YOUR E36 ═══ -->
  <section class="section diag-section">
    <div class="section-inner">
      <div class="section-tag">Diagnostics</div>
      <h2 class="section-title">TALK TO <em class="accent-em">your E36</em></h2>
      <p class="section-sub">Read fault codes, log live data, and understand what the car is telling you.</p>
      <div class="diag-grid">
        <div class="diag-card">
          <div class="diag-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M6 8h.01M9 8h6"/></svg>
          </div>
          <h3 class="diag-title">INPA / EDIABAS</h3>
          <p class="diag-desc">Native BMW diagnostics. Read and clear fault codes, access live sensor data, run actuator tests.</p>
          <a href="/guides" class="diag-link">Setup guide →</a>
        </div>
        <div class="diag-card">
          <div class="diag-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <h3 class="diag-title">Fault code log</h3>
          <p class="diag-desc">Document active and resolved faults across your build. Track patterns over time.</p>
          <a href="/tools/inpa-log" class="diag-link">Open tool →</a>
        </div>
        <div class="diag-card">
          <div class="diag-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h18v18H3z" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          </div>
          <h3 class="diag-title">OBD-II via ELM327</h3>
          <p class="diag-desc">Budget option with Torque or OBD Fusion. Limited vs INPA but works for basic fault reading.</p>
          <a href="/guides" class="diag-link">Comparison →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SCHEMAS & BLUEPRINTS ═══ -->
  <section class="section alt schema-section" style="position:relative;overflow:hidden;">
    <div class="schema-bg-img" aria-hidden="true">
      <img src="/images/IMG_0511.jpg" alt="" width="900" height="400" />
    </div>
    <div class="section-inner" style="position:relative;z-index:1;">
      <div class="section-tag">Technical docs</div>
      <h2 class="section-title">SCHEMAS <em class="accent-em">&amp; blueprints</em></h2>
      <p class="section-sub">Wiring diagrams, part locations, and installation references from the actual build.</p>
      <div class="schema-grid">
        {[
          { title: 'M50 swap wiring',     tag: 'Wiring' },
          { title: 'Climate control loom', tag: 'Wiring' },
          { title: 'Suspension geometry',  tag: 'Suspension' },
          { title: 'Cooling layout',       tag: 'Engine' },
          { title: 'Electric windows',     tag: 'Retrofit' },
          { title: 'Air management',       tag: 'Air suspension' },
        ].map(s => (
          <div class="schema-card">
            <span class="schema-tag">{s.tag}</span>
            <span class="schema-title">{s.title}</span>
          </div>
        ))}
      </div>
      <div class="section-more">
        <a href="/guides" class="btn-outline">All schemas →</a>
      </div>
    </div>
  </section>

  <!-- ═══ TOOLS STRIP ═══ -->
  <section class="section tools-strip-section">
    <div class="section-inner">
      <div class="tools-strip-layout">
        <div>
          <div class="section-tag">Interactive tools</div>
          <h2 class="section-title">EVERY PART<br><em class="accent-em">calculated.</em></h2>
          <p class="section-body">
            Wheel fitment, swap checklists, build budget, suspension geometry — tools built around real E36 work.
          </p>
          <a href="/tools" class="btn-primary">Open tools →</a>
        </div>
        <div class="tools-mini-grid">
          {[
            { title: 'Wheel Fitment', badge: 'Live' },
            { title: 'Swap Checklist', badge: 'Soon' },
            { title: 'Build Budget', badge: 'Soon' },
            { title: 'Tire Compare', badge: 'Soon' },
          ].map(t => (
            <div class={`tools-mini-card ${t.badge === 'Live' ? 'live' : 'soon'}`}>
              <span class="mini-badge">{t.badge}</span>
              <span class="mini-title">{t.title}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MERCH ═══ -->
  <section class="section alt merch-section">
    <div class="section-inner">
      <div class="merch-layout">
        <div class="merch-content">
          <div class="section-tag">projekt36 shop</div>
          <h2 class="section-title">WEAR THE<br><em class="accent-em">project</em></h2>
          <p class="section-body">
            Apparel and prints from the build. No fast fashion — just clean designs for people who actually wrench.
          </p>
          <a href="/shop" class="btn-primary">Visit shop →</a>
        </div>
        <div class="merch-image">
          <img src="/images/merch-mockup.png" alt="STATUS: PROJECT. t-shirt and mug" width="600" height="600" />
          <div class="merch-products">
            <img src="/images/merch-10mm.png" alt="The 10mm" width="200" height="200" />
            <img src="/images/merch-coolant.png" alt="The Coolant System" width="200" height="200" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ NEWSLETTER ═══ -->
  <section class="newsletter-section">
    <div class="section-inner">
      <p class="nl-tagline">Follow the swap. No spam, just sparks.</p>
      <form class="nl-form" id="nlForm">
        <input type="email" class="nl-input" placeholder="your@email.com" required />
        <button type="submit" class="nl-btn">Subscribe</button>
      </form>
      <p class="nl-note">Build updates, guide drops, and tool releases. Unsubscribe any time.</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
    padding: 0 1.5rem 6rem;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(11,14,18,1) 0%, rgba(11,14,18,0.6) 40%, rgba(11,14,18,0.3) 100%);
  }
  .hero-car {
    position: absolute;
    right: 0;
    bottom: 4rem;
    width: 55%;
    max-width: 780px;
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }
  .hero-car img {
    width: 100%;
    height: auto;
    display: block;
    mix-blend-mode: screen;
  }
  @media (max-width: 768px) { .hero-car { width: 100%; opacity: 0.1; } }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: var(--wide-w);
    margin: 0 auto;
    width: 100%;
  }
  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    letter-spacing: 0.15em;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .hero-dot { color: var(--accent); opacity: 0.6; }

  .hero-title {
    font-size: clamp(3.5rem, 9vw, 7rem);
    font-weight: 800;
    color: var(--text);
    line-height: 0.95;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }
  .hero-em {
    font-style: italic;
    font-weight: 300;
    color: var(--accent);
  }
  .hero-lead {
    font-size: 1rem;
    color: var(--text-mid);
    max-width: 52ch;
    line-height: 1.75;
    margin-bottom: 2rem;
  }
  .hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  /* ── STATS ── */
  .stats-strip {
    background: var(--bg2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 2rem 1.5rem;
  }
  .stats-inner {
    max-width: var(--wide-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 2.5rem;
  }
  .stat-num {
    font-family: var(--font-mono);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .stat-div {
    width: 1px;
    height: 40px;
    background: var(--border);
    flex-shrink: 0;
  }
  @media (max-width: 600px) {
    .stat-div { display: none; }
    .stat { padding: 0.5rem 1.2rem; }
  }

  /* ── SECTIONS (shared) ── */
  .section { padding: 5rem 1.5rem; }
  .section.alt { background: var(--bg2); }
  .section-inner { max-width: var(--wide-w); margin: 0 auto; }
  .section-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--text);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
  }
  .accent-em { font-style: italic; font-weight: 300; color: var(--accent); }
  .section-sub {
    font-size: 0.95rem;
    color: var(--text-mid);
    max-width: 56ch;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }
  .section-body {
    font-size: 0.95rem;
    color: var(--text-mid);
    max-width: 48ch;
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .section-more { margin-top: 2rem; }

  /* ── CHAPTERS ── */
  .chapters-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  @media (max-width: 780px) { .chapters-layout { grid-template-columns: 1fr; } }
  .chapter-list { display: flex; flex-direction: column; gap: 0; }
  .chapter-row {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
  }
  .chapter-row:last-child { border-bottom: none; }
  .chapter-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
    flex-shrink: 0;
    min-width: 2ch;
  }
  .chapter-name {
    font-size: 0.85rem;
    color: var(--text-mid);
    transition: color 0.15s;
  }
  .chapter-row:hover .chapter-name { color: var(--text); }

  /* ── WEAK POINTS ── */
  .weak-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-bottom: 2rem;
  }
  .weak-card {
    background: var(--bg2);
    padding: 1.5rem;
    transition: background 0.15s;
  }
  .weak-card:hover { background: var(--bg3); }
  .weak-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.6rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--accent);
    display: inline-block;
  }
  .weak-desc { font-size: 0.82rem; color: var(--text-mid); line-height: 1.6; }

  /* ── DIAGNOSTICS ── */
  .diag-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .diag-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-top: 3px solid var(--accent);
    padding: 1.75rem 1.5rem;
  }
  .diag-icon {
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .diag-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.6rem;
  }
  .diag-desc {
    font-size: 0.83rem;
    color: var(--text-mid);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }
  .diag-link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .diag-link:hover { opacity: 0.7; }

  /* ── SCHEMAS ── */
  .schema-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-bottom: 2rem;
  }
  .schema-card {
    background: var(--bg);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: background 0.15s;
  }
  .schema-card:hover { background: var(--bg3); }
  .schema-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .schema-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text);
  }

  /* ── TOOLS STRIP ── */
  .tools-strip-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 780px) { .tools-strip-layout { grid-template-columns: 1fr; } }
  .tools-mini-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .tools-mini-card {
    background: var(--bg2);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .tools-mini-card.live { background: var(--bg3); }
  .mini-badge {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }
  .tools-mini-card.live .mini-badge { color: var(--green); }
  .tools-mini-card.soon .mini-badge { color: var(--text-dim); }
  .mini-title { font-size: 0.85rem; font-weight: 600; color: var(--text); }

  /* ── SCHEMA BG ── */
  .schema-bg-img {
    position: absolute;
    bottom: 0; right: 0;
    width: 60%;
    opacity: 0.06;
    pointer-events: none;
    mix-blend-mode: screen;
  }
  .schema-bg-img img { width: 100%; height: auto; }

  /* ── MERCH ── */
  .merch-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 780px) { .merch-layout { grid-template-columns: 1fr; } }
  .merch-image { position: relative; }
  .merch-image > img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--border);
  }
  .merch-products {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    margin-top: 1px;
  }
  .merch-products img {
    width: 100%;
    height: auto;
    display: block;
    filter: brightness(0.9);
    transition: filter 0.2s;
  }
  .merch-products img:hover { filter: brightness(1.05); }

  /* ── NEWSLETTER ── */
  .newsletter-section {
    background: var(--bg);
    border-top: 1px solid var(--border);
    padding: 4rem 1.5rem;
    text-align: center;
  }
  .nl-tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }
  .nl-form {
    display: flex;
    gap: 0;
    max-width: 440px;
    margin: 0 auto 1rem;
  }
  .nl-input {
    flex: 1;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-right: none;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .nl-input:focus { border-color: var(--accent); }
  .nl-btn {
    background: var(--accent);
    color: #000;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.75rem 1.5rem;
    border: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .nl-btn:hover { opacity: 0.85; }
  .nl-note {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
  }
</style>
