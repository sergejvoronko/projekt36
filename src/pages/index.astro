---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="projekt36 — BMW E36 Build Journal & Tools">
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "projekt36",
  "url": "https://projekt36.com",
  "description": "BMW E36 build journal, retrofit guides, and practical tools for E36 owners.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://projekt36.com/guides?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
})} slot="head" />

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-grid"></div>
      <div class="hero-blueprint">
        <img src="/images/blueprint-engine.webp" alt="" width="1408" height="768" loading="lazy" decoding="async" />
      </div>
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-car" aria-hidden="true">
      <img src="/images/IMG_0511 (1).webp" alt="" width="900" height="400" />
    </div>
    <!-- HUD telemetry chips — upper-left area -->
    <div class="hero-hud" aria-hidden="true">
      <div class="hud-chip">
        <span class="hud-key">Chassis</span>
        <span class="hud-val">E36 Sedan</span>
      </div>
      <div class="hud-chip">
        <span class="hud-key">Engine</span>
        <span class="hud-val">M43B16</span>
      </div>
      <div class="hud-chip">
        <span class="hud-key">Year</span>
        <span class="hud-val">1994</span>
      </div>
      <div class="hud-chip">
        <span class="hud-key">Odometer</span>
        <span class="hud-val">230,000+ km</span>
      </div>
      <div class="hud-chip hud-status">
        <span class="hud-dot"></span>
        <span class="hud-val">Build in progress</span>
      </div>
    </div>

    <div class="hero-inner">
      <div class="hero-label">
        <span>PROJEKT36</span>
        <span class="hero-dot">·</span>
        <span>BUILD JOURNAL</span>
        <span class="hero-dot">·</span>
        <span>RETROFIT GUIDES</span>
        <span class="hero-dot">·</span>
        <span>E36 TOOLS</span>
      </div>
      <h1 class="hero-title">
        <span>316i </span><em class="hero-em">becomes</em><br><span>something more</span>
      </h1>
      <p class="hero-lead">
        One BMW E36 Sedan. Documented from the first fault code to final drive.
        Engine swap, wiring, suspension, sound, paint — eleven chapters, one transformation.
      </p>
      <div class="hero-ctas">
        <a href="/build" class="btn-primary">Build Journal →</a>
        <a href="/tools" class="btn-outline">Explore Tools</a>
        <a href="/guides" class="btn-outline">Guides</a>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section class="stats-strip">
    <div class="stats-inner">
      <div class="stat">
        <span class="stat-num">25</span>
        <span class="stat-label">Technical guides</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">6</span>
        <span class="stat-label">Interactive tools</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">5</span>
        <span class="stat-label">Wiring schemas</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">11</span>
        <span class="stat-label">Build chapters</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-num">316i</span>
        <span class="stat-label">The car</span>
      </div>
    </div>
  </section>

  <!-- ═══ BUILD STATUS ═══ -->
  <section class="build-status-section">
    <div class="section-inner">

      <div class="bs-top">
        <div class="bs-chapter-block">
          <span class="bs-meta-label">Current Chapter</span>
          <span class="bs-chapter-val">01 — Teardown</span>
        </div>
        <div class="bs-status-block">
          <span class="bs-meta-label">Status</span>
          <span class="bs-status-val"><span class="bs-dot"></span>In Progress</span>
        </div>
      </div>

      <div class="bs-progress-row">
        <span class="bs-prog-label">Overall Progress</span>
        <span class="bs-prog-pct">15%</span>
      </div>
      <div class="bs-track">
        <div class="bs-fill" style="width:15%">
          <div class="bs-thumb"></div>
        </div>
      </div>

      <!-- Logo badge between progress bar and grille — like BMW roundel between kidneys -->
      <div class="grill-logo-bridge">
        <div class="grill-logo-line"></div>
        <div class="grill-logo-badge">
          <img src="/images/projekt36-mark.svg" alt="projekt36" width="48" height="48" />
        </div>
        <div class="grill-logo-line"></div>
      </div>

      <!-- Kidney grille comparison -->
      <div class="grill-compare">
        <div class="grill-kidney grill-now">
          <div class="grill-kidney-label">What it is now</div>
          <div class="grill-slats">
            <div class="grill-slat">M43B16 · 102 hp · 4-cyl</div>
            <div class="grill-slat">Manual windows · No A/C</div>
            <div class="grill-slat">Stock springs · No damping</div>
            <div class="grill-slat">Grey cloth · Zero insulation</div>
            <div class="grill-slat">Rust in sills &amp; arches</div>
            <div class="grill-slat">Steel stock 15&quot; wheels</div>
          </div>
        </div>

        <div class="grill-bridge">
          <span class="grill-arrow">→</span>
        </div>

        <div class="grill-kidney grill-become">
          <div class="grill-kidney-label">What it will become</div>
          <div class="grill-slats">
            <div class="grill-slat">M50B25 NV · 189 hp · I6</div>
            <div class="grill-slat">Climate control retrofit</div>
            <div class="grill-slat">Air suspension · Adjustable</div>
            <div class="grill-slat">Black leather · Full sound deadening</div>
            <div class="grill-slat">Fresh paint + PPF protection</div>
            <div class="grill-slat">Custom 3-piece wheels</div>
          </div>
        </div>
      </div>

      <div class="bs-cta">
        <a href="/build" class="btn-primary">Follow the build →</a>
      </div>

    </div>
  </section>

  <!-- ═══ ELEVEN CHAPTERS ═══ -->
  <section class="section chapters-section">
    <div class="section-inner">
      <div class="chapters-layout">
        <div class="chapters-content">
          <div class="section-tag">The build narrative</div>
          <h2 class="section-title">ELEVEN CHAPTERS.<br><em class="accent-em">ONE TRANSFORMATION.</em></h2>
          <p class="section-body">
            From a stock 316i Sedan with a tired M43 to a proper driver's car with an M50 under the bonnet.
            Every decision documented — what worked, what failed, what it cost.
          </p>
          <a href="/build" class="btn-primary">Start reading →</a>
        </div>
        <div class="chapters-meta">
          <div class="chapter-list">
            {[
              'Teardown & diagnosis',
              'Engine pull — M43 out',
              'Bay prep & rust work',
              'M50 conversion',
              'Cooling & ancillaries',
              'Wiring & ECU',
              'Suspension rebuild',
              'Interior & sound',
              'Paint & body',
              'Wheels & fitment',
              'First drive & tuning',
            ].map((ch, i) => (
              <div class="chapter-row">
                <span class="chapter-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="chapter-name">{ch}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WEAK POINTS ═══ -->
  <section class="section alt weak-section">
    <div class="section-inner">
      <div class="section-tag">Know your car</div>
      <h2 class="section-title">EVERY E36's <em class="accent-em">WEAK POINTS</em></h2>
      <p class="section-sub">The recurring failures every E36 owner will face — and how to get ahead of them.</p>
      <div class="weak-grid">
        {[
          { n: '01', title: 'Cooling system',      desc: 'Plastic thermostat housing, expansion tank, and radiator all crack with age. Replace preventively.' },
          { n: '02', title: 'Rear subframe',        desc: 'Subframe mounts tear through the chassis on high-mileage or lowered cars. Weld before it cracks.' },
          { n: '03', title: 'DISA valve',           desc: 'M52/M54 only. The plastic paddle fails, causing rough idle and power loss. Cheap fix, high impact.' },
          { n: '04', title: 'Window regulators',    desc: 'Plastic clips snap on all doors. Replace with metal-clip units or budget for repeated fixes.' },
          { n: '05', title: 'Rear trailing arms',   desc: 'Bushings collapse, causing vague rear handling. Polyurethane or pillow-ball arms fix this properly.' },
          { n: '06', title: 'Electrical gremlins',  desc: 'Door loom wears through the grommet, killing windows and locks. Reroute and sleeve the harness.' },
        ].map(wp => (
          <div class="weak-card">
            <span class="weak-num">{wp.n}</span>
            <h3 class="weak-title">{wp.title}</h3>
            <p class="weak-desc">{wp.desc}</p>
          </div>
        ))}
      </div>
      <div class="section-more">
        <a href="/guides" class="btn-outline">All guides →</a>
      </div>
    </div>
  </section>

  <!-- ═══ TALK TO YOUR E36 ═══ -->
  <section class="section diag-section">
    <div class="section-inner">
      <div class="section-tag">Diagnostics</div>
      <h2 class="section-title">TALK TO <em class="accent-em">your E36</em></h2>
      <p class="section-sub">Pre-facelift E36s don't speak standard OBD2. They use BMW's proprietary ADS protocol through the round 20-pin connector. Here's what you actually need to read codes, monitor sensors, and verify your swap.</p>
      <div class="diag-grid">
        <div class="diag-card">
          <div class="diag-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M6 8h.01M9 8h6"/></svg>
          </div>
          <h3 class="diag-title">INPA / EDIABAS</h3>
          <div class="diag-type">SOFTWARE</div>
          <p class="diag-desc">BMW's own dealer diagnostic software. Reads every sensor, every fault code, every live parameter the DME knows. Essential for verifying the M50 swap — confirming O2 readings, idle control, VANOS timing (if TU), and cooling fan triggers.</p>
          <a href="/guides/e36-inpa-setup-guide" class="diag-link">Setup guide →</a>
        </div>
        <div class="diag-card">
          <div class="diag-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/><circle cx="12" cy="12" r="4"/></svg>
          </div>
          <h3 class="diag-title">ADS Serial Interface</h3>
          <div class="diag-type">HARDWARE</div>
          <p class="diag-desc">Not a K+DCAN cable — those won't work on pre-facelift OBD1 cars. You need a true ADS serial interface that connects to the round 20-pin diagnostic connector and speaks BMW's DS2 protocol via RS232.</p>
          <a href="/guides/e36-obd1-diagnostic-setup" class="diag-link">Which interface to buy →</a>
        </div>
        <div class="diag-card">
          <div class="diag-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M8 10h8M8 7h3"/></svg>
          </div>
          <h3 class="diag-title">Old ThinkPad + RS232</h3>
          <div class="diag-type">SETUP</div>
          <p class="diag-desc">A used ThinkPad T60/T61 with native serial port running Windows XP is the most reliable INPA setup. No USB-serial adapter headaches. Available on bazos.sk for €20–40.</p>
          <a href="/guides/e36-inpa-setup-guide" class="diag-link">Full setup guide →</a>
        </div>
      </div>

      <div class="diag-terminal">
        <div class="dt-line"><span class="dt-prompt">&gt;</span> <span class="dt-input">your car: E36 sedan, Jan 1994, pre-facelift</span></div>
        <div class="dt-line"><span class="dt-key">Protocol:</span> <span class="dt-hl">ADS only</span> <span class="dt-comment">(no K-line on this chassis)</span></div>
        <div class="dt-line"><span class="dt-key">Connector:</span> <span class="dt-hl">20-pin round</span> <span class="dt-comment">(under hood, left side)</span></div>
        <div class="dt-line"><span class="dt-key">DME after swap:</span> <span class="dt-hl">Bosch M3.1 or M3.3</span> <span class="dt-comment">(M50 NV)</span></div>
        <div class="dt-line"><span class="dt-key">Interface needed:</span> <span class="dt-hl dt-warn">ADS serial → NOT K+DCAN USB</span></div>
        <div class="dt-line"><span class="dt-key">Software:</span> <span class="dt-hl">INPA 5.0.2 + EDIABAS 7.3.0</span></div>
        <div class="dt-spacer"></div>
        <div class="dt-line dt-dim"><span class="dt-comment">Stomp test (no laptop): Turn key to pos. 2 → floor gas 5x in 5 sec → CEL flashes codes</span></div>
      </div>

      <div class="section-more">
        <a href="/guides/e36-obd1-diagnostic-setup" class="btn-outline">Read full diagnostic guide →</a>
      </div>
    </div>
  </section>

  <!-- ═══ SCHEMAS & BLUEPRINTS ═══ -->
  <section class="section alt schema-section">
    <div class="section-inner">
      <div class="section-tag">Technical docs</div>
      <h2 class="section-title">SCHEMAS <em class="accent-em">&amp; blueprints</em></h2>
      <p class="section-sub">Wiring diagrams, part locations, and installation references from the actual build.</p>
      <div class="schema-list">
        {[
          { num: '01', title: 'M50 swap wiring',      tag: 'Wiring',         avail: true  },
          { num: '02', title: 'Climate control loom',  tag: 'Wiring',         avail: true  },
          { num: '03', title: 'Suspension geometry',   tag: 'Suspension',     avail: true  },
          { num: '04', title: 'Cooling layout',        tag: 'Engine',         avail: true  },
          { num: '05', title: 'Electric windows',      tag: 'Retrofit',       avail: false },
          { num: '06', title: 'Air management',        tag: 'Air suspension', avail: false },
        ].map(s => (
          <div class={`schema-row ${s.avail ? 'avail' : 'draft'}`}>
            <span class="schema-num">{s.num}</span>
            <span class="schema-name">{s.title}</span>
            <span class="schema-cat">{s.tag}</span>
            <span class={`schema-status ${s.avail ? 'avail' : 'draft'}`}>{s.avail ? 'Available' : 'In progress'}</span>
          </div>
        ))}
      </div>
      <div class="section-more">
        <a href="/schemas/e36-wiring.html" target="_blank" class="btn-outline">Open wiring viewer →</a>
      </div>
    </div>
  </section>

  <!-- ═══ TOOLS STRIP ═══ -->
  <section class="section tools-strip-section">
    <div class="section-inner">
      <div class="tools-strip-layout">
        <div>
          <div class="section-tag">Interactive tools</div>
          <h2 class="section-title">EVERY PART<br><em class="accent-em">calculated.</em></h2>
          <p class="section-body">
            Wheel fitment, swap checklists, build budget, suspension geometry — tools built around real E36 work.
          </p>
          <a href="/tools" class="btn-primary">Open tools →</a>
        </div>
        <div class="tools-mini-grid">
          {[
            { title: 'Wheel Fitment',   href: '/tools/wheel-fitment' },
            { title: 'Swap Checklist',  href: '/tools/swap-checklist' },
            { title: 'Build Budget',    href: '/tools/build-budget' },
            { title: 'Tire Compare',    href: '/tools/tire-compare' },
            { title: 'Offset & Spacer', href: '/tools/offset-spacer' },
            { title: 'Air Suspension',  href: '/tools/air-suspension' },
          ].map(t => (
            <a href={t.href} class="tools-mini-card live">
              <span class="mini-badge">Live</span>
              <span class="mini-title">{t.title}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MERCH ═══ -->
  <section class="section alt merch-section">
    <div class="section-inner">
      <div class="merch-layout">
        <div class="merch-content">
          <div class="section-tag">projekt36 shop</div>
          <h2 class="section-title">WEAR THE<br><em class="accent-em">project</em></h2>
          <p class="section-body">
            Apparel and prints from the build. No fast fashion — just clean designs for people who actually wrench.
          </p>
          <a href="/shop" class="btn-primary">Visit shop →</a>
        </div>
        <div class="merch-image">
          <img src="/images/merch-mockup.webp" alt="STATUS: PROJECT. t-shirt and mug" width="600" height="600" />
          <div class="merch-products">
            <img src="/images/merch-10mm.webp" alt="The 10mm" width="200" height="200" />
            <img src="/images/merch-coolant.webp" alt="The Coolant System" width="200" height="200" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ NEWSLETTER ═══ -->
  <section class="newsletter-section">
    <div class="section-inner">
      <p class="nl-tagline">Follow the swap. No spam, just sparks.</p>
      <form class="nl-form" id="nlForm">
        <input type="email" class="nl-input" placeholder="your@email.com" required />
        <button type="submit" class="nl-btn">Subscribe</button>
      </form>
      <p class="nl-note" id="nlNote">Build updates, guide drops, and tool releases. Unsubscribe any time.</p>
    </div>
  </section>

</BaseLayout>

<script>
  // Newsletter form
  document.getElementById('nlForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const note = document.getElementById('nlNote');
    form.style.display = 'none';
    if (note) {
      note.textContent = '✓ You\'re in. Build updates coming your way.';
      note.style.color = 'var(--green)';
      note.style.fontSize = '0.9rem';
    }
  });
</script>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
    padding: 0 1.5rem 6rem;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(212,149,42,0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212,149,42,0.055) 1px, transparent 1px),
      linear-gradient(rgba(212,149,42,0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212,149,42,0.022) 1px, transparent 1px);
    background-size: 80px 80px, 80px 80px, 20px 20px, 20px 20px;
    pointer-events: none;
  }
  .hero-blueprint {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    mix-blend-mode: screen;
    opacity: 0.22;
  }
  .hero-blueprint img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(11,14,18,1) 0%, rgba(11,14,18,0.6) 40%, rgba(11,14,18,0.3) 100%);
  }
  .hero-car {
    position: absolute;
    right: 0;
    bottom: 4rem;
    width: 55%;
    max-width: 780px;
    opacity: 0.55;
    pointer-events: none;
    z-index: 0;
    animation: hero-car-in 1.2s ease-out both;
    animation-delay: 0.4s;
  }
  @keyframes hero-car-in {
    from { opacity: 0; transform: translateX(40px); }
    to   { opacity: 0.55; transform: translateX(0); }
  }
  .hero-car img {
    width: 100%;
    height: auto;
    display: block;
  }
  @media (max-width: 768px) { .hero-car { width: 100%; opacity: 0.2; } }
  /* HUD chips */
  .hero-hud {
    position: absolute;
    top: clamp(5rem, 12vw, 8rem);
    left: clamp(1.5rem, 4vw, 3rem);
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    animation: hero-fade-up 0.9s ease both;
    animation-delay: 0.6s;
  }
  .hud-chip {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    background: rgba(19, 23, 32, 0.55);
    border: 1px solid rgba(255,255,255,0.06);
    border-left: 2px solid rgba(212,149,42,0.35);
    padding: 0.3rem 0.75rem 0.3rem 0.6rem;
    backdrop-filter: blur(6px);
    width: fit-content;
  }
  .hud-key {
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.58rem;
    flex-shrink: 0;
  }
  .hud-val {
    color: var(--text-mid);
    letter-spacing: 0.04em;
  }
  .hud-status .hud-val {
    color: var(--green);
  }
  .hud-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
    animation: bs-pulse 2s ease-in-out infinite;
  }
  @media (max-width: 768px) { .hero-hud { display: none; } }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: var(--wide-w);
    margin: 0 auto;
    width: 100%;
  }
  .hero-inner > * {
    animation: hero-fade-up 0.7s ease both;
  }
  .hero-inner .hero-label  { animation-delay: 0.05s; }
  .hero-inner .hero-title  { animation-delay: 0.15s; }
  .hero-inner .hero-lead   { animation-delay: 0.25s; }
  .hero-inner .hero-ctas   { animation-delay: 0.35s; }
  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    letter-spacing: 0.15em;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .hero-dot { color: var(--accent); opacity: 0.6; }

  .hero-title {
    font-size: clamp(3.5rem, 9vw, 7rem);
    font-weight: 600;
    color: var(--text);
    line-height: 0.95;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }
  .hero-em {
