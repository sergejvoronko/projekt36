---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
const id = `nl-${Math.random().toString(36).slice(2, 7)}`;
---

<div class={`subscribe-box ${compact ? 'subscribe-compact' : ''}`}>
  <div class="sub-inner">
    <div class="sub-text">
      <div class="sub-tag">Build updates</div>
      <p class="sub-heading">Follow the swap.</p>
      <p class="sub-note">New guides, build chapters, and tool releases — no spam, just sparks.</p>
    </div>
    <form class="sub-form" id={id}>
      <div class="sub-fields">
        <input type="email" class="sub-input" placeholder="your@email.com" required aria-label="Email address" />
        <button type="submit" class="sub-btn">Subscribe</button>
      </div>
      <p class="sub-fine" id={`${id}-note`}>Unsubscribe any time. No third parties.</p>
    </form>
  </div>
</div>

<script define:vars={{ id }}>
  document.getElementById(id)?.addEventListener('submit', e => {
    e.preventDefault();
    const form = e.currentTarget;
    const note = document.getElementById(`${id}-note`);
    form.querySelector('.sub-fields').style.display = 'none';
    if (note) {
      note.textContent = '✓ You\'re in. Build updates on the way.';
      note.style.color = 'var(--green)';
      note.style.fontSize = '0.85rem';
    }
  });
</script>

<style>
  .subscribe-box {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-top: 2px solid var(--accent);
    padding: 2rem 2.25rem;
    margin: 3rem 0;
  }
  .subscribe-compact {
    padding: 1.5rem 1.75rem;
    margin: 2rem 0;
  }
  .sub-inner {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .sub-text { flex: 1; min-width: 180px; }
  .sub-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 0.4rem;
  }
  .sub-heading {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }
  .subscribe-compact .sub-heading { font-size: 0.95rem; }
  .sub-note {
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.55;
  }
  .sub-form { flex: 1; min-width: 240px; }
  .sub-fields {
    display: flex;
    gap: 0;
  }
  .sub-input {
    flex: 1;
    background: var(--bg3);
    border: 1px solid var(--border-mid);
    border-right: none;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.6rem 0.9rem;
    outline: none;
    transition: border-color 0.15s;
    min-width: 0;
  }
  .sub-input:focus { border-color: var(--accent); }
  .sub-btn {
    background: var(--accent);
    color: var(--text-inverse);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.6rem 1.25rem;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .sub-btn:hover { opacity: 0.85; }
  .sub-fine {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-top: 0.5rem;
  }
</style>
